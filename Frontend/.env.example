# =============================================
# StableRisk Environment Configuration
# =============================================
# Copy this file to .env and adjust values

# ACTUS Environment: "localhost" or "aws"
# localhost → Docker on your machine (8082/8083)
# aws       → AWS server at 34.203.247.32 (8082/8083)
NEXT_PUBLIC_ACTUS_ENVIRONMENT=localhost

# Backend API base URL (the Express server on port 4000)
NEXT_PUBLIC_API_BASE=http://localhost:4000/api
