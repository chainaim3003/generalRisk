    {
      "name": "6. Run Simulation",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Step 6: Simulation succeeded', function () {",
              "    pm.response.to.have.status(200);",
              "    var data = pm.response.json();",
              "    pm.expect(data[0].status).to.eql('Success');",
              "    var events = data[0].events;",
              "    console.log('PASS: ' + events.length + ' events generated');",
              "    var counts = {};",
              "    events.forEach(function(e){ counts[e.type] = (counts[e.type]||0)+1; });",
              "    Object.keys(counts).forEach(function(k){ console.log('  ' + k + ': ' + counts[k]); });",
              "    var pps = events.filter(function(e){ return e.type==='PP'; });",
              "    pps.forEach(function(pp){",
              "        var action = pp.payoff > 0 ? 'PREPAID $'+pp.payoff : 'no prepay';",
              "        console.log('  PP ' + pp.time + ' -> ' + action + ' | notional=$' + pp.nominalValue);",
              "    });",
              "    var ip = events.filter(function(e){return e.type==='IP';})[0];",
              "    var md = events.filter(function(e){return e.type==='MD';})[0];",
              "    console.log('  Interest paid: $' + ip.payoff.toFixed(2));",
              "    console.log('  Principal returned: $' + md.payoff.toFixed(2));",
              "});"
            ]
          }
        }
