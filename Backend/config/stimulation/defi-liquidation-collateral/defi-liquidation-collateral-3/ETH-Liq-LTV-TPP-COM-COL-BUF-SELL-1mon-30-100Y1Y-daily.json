    {
      "name": "7. Run Portfolio Simulation - OPTION B (Buffer-First)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Step 7: OPTION B Buffer-First simulation', function(){",
              "    pm.response.to.have.status(200);",
              "    var data = pm.response.json();",
              "    console.log('════════════════════════════════════════════════════════════');",
              "    console.log('OPTION B: BUFFER-FIRST LIQUIDATION DEFENSE');",
              "    console.log('════════════════════════════════════════════════════════════');",
              "    console.log('Total contracts simulated: ' + data.length);",
              "    console.log('');",
              "    ",
              "    var collateralCOM = data.find(function(c){return (c.contractId||c.contractID||'').includes('Collateral');});",
              "    var bufferCOM = data.find(function(c){return (c.contractId||c.contractID||'').includes('Buffer');});",
              "    var pamLoan = data.find(function(c){return (c.contractId||c.contractID||'').includes('DeFi-ETH');});",
              "    ",
              "    console.log('══ PORTFOLIO BREAKDOWN ══');",
              "    if(collateralCOM){",
              "        console.log('1. Collateral ETH (COM): 3.0 ETH - ' + (collateralCOM.events||[]).length + ' events');",
              "        console.log('   → Quantity NEVER changes (Option B characteristic)');",
              "    }",
              "    if(bufferCOM){",
              "        console.log('2. Buffer ETH (COM): 4.0 ETH - ' + (bufferCOM.events||[]).length + ' events');",
              "        console.log('   → Defense fund (depletes on interventions)');",
              "    }",
              "    if(pamLoan){",
              "        var events = pamLoan.events || [];",
              "        console.log('3. Loan (PAM): $5,000 - ' + events.length + ' events');",
              "        var rrCount = events.filter(function(e){return e.type==='RR';}).length;",
              "        var ipCount = events.filter(function(e){return e.type==='IP';}).length;",
              "        var ppCount = events.filter(function(e){return e.type==='PP';}).length;",
              "        console.log('   → RR (Rate Reset): ' + rrCount);",
              "        console.log('   → IP (Interest): ' + ipCount);",
              "        console.log('   → PP (Prepayment): ' + ppCount);",
              "    }",
              "    console.log('');",
              "    ",
              "    if(pamLoan && pamLoan.events){",
              "        var events = pamLoan.events;",
              "        var pps = events.filter(function(e){return e.type==='PP' && e.payoff > 0;});",
              "        if(pps.length > 0){",
              "            console.log('══ BUFFER INTERVENTIONS DETECTED ══');",
              "            console.log('Look for BufferLTVModel intervention logs in Java console:');",
              "            console.log('  → \"**** BufferLTVModel INTERVENTION ****\"');",
              "            console.log('  → Shows: ETH sold, USDC raised, buffer before/after');",
              "            console.log('  → Circuit breaker status after each intervention');",
              "            console.log('');",
              "            console.log('Total PP events: ' + pps.length);",
              "            pps.slice(0,3).forEach(function(pp){",
              "                console.log('  ' + pp.time + ': $' + pp.payoff.toFixed(2) + ' → loan=$' + pp.nominalValue.toFixed(2));",
              "            });",
              "            if(pps.length > 3) console.log('  ... and ' + (pps.length-3) + ' more');",
              "        }",
              "        console.log('');",
              "        ",
              "        var lastEvent = events[events.length - 1];",
              "        if(lastEvent){",
              "            console.log('══ FINAL STATE (Day 30) ══');",
              "            console.log('  Final notional: $' + (lastEvent.nominalValue || 0).toFixed(2));",
              "            console.log('  Contract status: OPEN (100-year perpetual)');",
              "            console.log('');",
              "            console.log('══ OPTION B KEY ADVANTAGE ══');",
              "            console.log('  Collateral: PRESERVED at 3.0 ETH (never liquidated)');",
              "            console.log('  LTV calculation: Always uses original 3.0 ETH');",
              "            console.log('  Result: Much healthier LTV after each defense');",
              "            console.log('');",
              "            console.log('  Compare to Option A:');",
              "            console.log('    Option A: Liquidates collateral → depleting quantity');",
              "            console.log('    Option B: Uses buffer → constant collateral ✅');",
              "        }",
              "    }",
              "    console.log('════════════════════════════════════════════════════════════');",
              "});"
            ]
          }
        }
