    {
      "name": "6. Run Simulation",
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Simulation executed', function(){",
            "  pm.response.to.have.status(200);",
            "  var data = pm.response.json();",
            "  console.log('Status: '+data[0].status);",
            "  if(data[0].status === 'Success'){",
            "    var events = data[0].events;",
            "    console.log('✅ Total events: '+events.length);",
            "    var pps = events.filter(e => e.type === 'PP');",
            "    console.log('✅ PP events: '+pps.length);",
            "    pps.forEach((pp,i) => console.log('  PP#'+(i+1)+' at '+pp.time+': payoff=$'+pp.payoff+', notional=$'+pp.nominalValue));",
            "  } else {",
            "    console.log('❌ Error: '+data[0].message);",
            "  }",
            "});"
          ]
        }
      }],
