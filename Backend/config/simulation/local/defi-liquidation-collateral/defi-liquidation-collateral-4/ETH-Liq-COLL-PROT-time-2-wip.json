            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contracts\": [\n    {\n      \"contractType\": \"CLM\",\n      \"contractID\": \"ETH-COLLATERAL-LOCKED\",\n      \"statusDate\": \"2024-12-31T23:59:00\",\n      \"contractRole\": \"RPA\",\n      \"currency\": \"ETH\",\n      \"contractDealDate\": \"2024-12-31T23:59:00\",\n      \"initialExchangeDate\": \"2025-01-01T00:00:00\",\n      \"notionalPrincipal\": 5.0,\n      \"nominalInterestRate\": 0.0,\n      \"dayCountConvention\": \"A365\",\n      \"cycleOfInterestPayment\": \"P1ML0\",\n      \"cycleAnchorDateOfInterestPayment\": \"2025-01-31T00:00:00\",\n      \"maturityDate\": \"2025-01-31T00:00:00\",\n      \"xDayNotice\": \"P1D\",\n      \"treasuryModels\": [\"scf_eth_additions\"]\n    },\n    {\n      \"contractType\": \"CLM\",\n      \"contractID\": \"ETH-RESERVE-AVAILABLE\",\n      \"statusDate\": \"2024-12-31T23:59:00\",\n      \"contractRole\": \"RPA\",\n      \"currency\": \"ETH\",\n      \"contractDealDate\": \"2024-12-31T23:59:00\",\n      \"initialExchangeDate\": \"2025-01-01T00:00:00\",\n      \"notionalPrincipal\": 5.0,\n      \"nominalInterestRate\": 0.0,\n      \"dayCountConvention\": \"A365\",\n      \"cycleOfInterestPayment\": \"P1ML0\",\n      \"cycleAnchorDateOfInterestPayment\": \"2025-01-31T00:00:00\",\n      \"maturityDate\": \"2025-01-31T00:00:00\",\n      \"xDayNotice\": \"P1D\"\n    },\n    {\n      \"calendar\": \"NC\",\n      \"businessDayConvention\": \"SCF\",\n      \"contractType\": \"PAM\",\n      \"statusDate\": \"2024-12-31T23:59:00\",\n      \"contractRole\": \"RPA\",\n      \"contractID\": \"LOAN-USD-9000\",\n      \"cycleAnchorDateOfInterestPayment\": \"2025-01-31T00:00:00\",\n      \"cycleOfInterestPayment\": \"P1ML0\",\n      \"nominalInterestRate\": 0.05,\n      \"dayCountConvention\": \"AA365S\",\n      \"currency\": \"USD\",\n      \"contractDealDate\": \"2024-12-31T23:59:00\",\n      \"initialExchangeDate\": \"2025-01-01T00:00:00\",\n      \"maturityDate\": \"2025-01-31T00:00:00\",\n      \"notionalPrincipal\": 9000,\n      \"premiumDiscountAtIED\": 0,\n      \"cycleAnchorDateOfRateReset\": \"2025-01-01T00:00:00\",\n      \"cycleOfRateReset\": \"P1DL0\",\n      \"rateSpread\": 0.0,\n      \"marketObjectCodeOfRateReset\": \"DEFI_RATE\",\n      \"prepaymentModels\": [\"defi_pp_30d_v3\", \"ltv_30d_v3\"]\n    },\n    {\n      \"calendar\": \"NC\",\n      \"businessDayConvention\": \"SCF\",\n      \"contractType\": \"PAM\",\n      \"contractID\": \"TREASURY-CASH-USD\",\n      \"statusDate\": \"2024-12-31T23:59:00\",\n      \"contractRole\": \"RPA\",\n      \"currency\": \"USD\",\n      \"contractDealDate\": \"2024-12-31T23:59:00\",\n      \"initialExchangeDate\": \"2025-01-01T00:00:00\",\n      \"maturityDate\": \"2025-01-31T00:00:00\",\n      \"notionalPrincipal\": 0.0,\n      \"nominalInterestRate\": 0.0,\n      \"dayCountConvention\": \"A365\",\n      \"premiumDiscountAtIED\": 0.0,\n      \"treasuryModels\": [\"scf_loan_disbursement\", \"scf_usd_payoffs\"]\n    }\n  ],\n  \"scenarioDescriptor\": {\"scenarioID\": \"defi_eth_full_scn\", \"scenarioType\": \"scenario\"},\n  \"simulateTo\": \"2025-02-01T00:00:00\",\n  \"monitoringTimes\": [\n    \"2025-01-01T00:00:00\",\n    \"2025-01-02T00:00:00\",\n    \"2025-01-04T00:00:00\",\n    \"2025-01-08T00:00:00\",\n    \"2025-01-11T00:00:00\",\n    \"2025-01-12T06:00:00\",\n    \"2025-01-12T12:00:00\",\n    \"2025-01-15T00:00:00\",\n    \"2025-01-17T00:00:00\",\n    \"2025-01-17T18:00:00\",\n    \"2025-01-22T00:00:00\",\n    \"2025-01-26T00:00:00\",\n    \"2025-01-31T00:00:00\"\n  ]\n}"
