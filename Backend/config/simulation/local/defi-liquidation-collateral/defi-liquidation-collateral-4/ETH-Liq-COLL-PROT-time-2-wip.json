    {
      "name": "══ PHASE 2: Asset-Only Run (derive flows) ══",
      "item": [
        {
          "name": "2.1 Phase 0 Scenario",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {
              "raw": "http://{{actus_risk_host}}/addScenario",
              "host": ["{{actus_risk_host}}"],
              "protocol": "http",
              "path": ["addScenario"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"scenarioID\": \"defi_eth_phase0_scn\",\n  \"riskFactorDescriptors\": [\n    {\"riskFactorID\": \"DEFI_RAT_30D_DAILY\", \"riskFactorType\": \"ReferenceIndex\"},\n    {\"riskFactorID\": \"ETH_PRICE_30D\", \"riskFactorType\": \"ReferenceIndex\"},\n    {\"riskFactorID\": \"defi_pp_30d_v3\", \"riskFactorType\": \"TwoDimensionalPrepaymentModel\"},\n    {\"riskFactorID\": \"ltv_30d_v3\", \"riskFactorType\": \"CollateralLTVModel\"}\n  ]\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["pm.test('Phase 0 Scenario',function(){pm.response.to.have.status(200);console.log('✅ defi_eth_phase0_scn: 4 descriptors');});"]
            }
          }]
        },
        {
          "name": "2.2 Run Asset-Only (capture PP events)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {
              "raw": "http://{{actus_sim_host}}/rf2/scenarioSimulation",
              "host": ["{{actus_sim_host}}"],
              "protocol": "http",
              "path": ["rf2", "scenarioSimulation"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contracts\": [{\n    \"calendar\": \"NC\",\n    \"businessDayConvention\": \"SCF\",\n    \"contractType\": \"PAM\",\n    \"statusDate\": \"2024-12-31T23:59:00\",\n    \"contractRole\": \"RPA\",\n    \"contractID\": \"LOAN-USD-PHASE0\",\n    \"cycleAnchorDateOfInterestPayment\": \"2025-01-31T00:00:00\",\n    \"cycleOfInterestPayment\": \"P1ML0\",\n    \"nominalInterestRate\": 0.05,\n    \"dayCountConvention\": \"AA365S\",\n    \"currency\": \"USD\",\n    \"contractDealDate\": \"2024-12-31T23:59:00\",\n    \"initialExchangeDate\": \"2025-01-01T00:00:00\",\n    \"maturityDate\": \"2025-01-31T00:00:00\",\n    \"notionalPrincipal\": 9000,\n    \"premiumDiscountAtIED\": 0,\n    \"cycleAnchorDateOfRateReset\": \"2025-01-01T00:00:00\",\n    \"cycleOfRateReset\": \"P1DL0\",\n    \"rateSpread\": 0.0,\n    \"marketObjectCodeOfRateReset\": \"DEFI_RATE\",\n    \"prepaymentModels\": [\"defi_pp_30d_v3\", \"ltv_30d_v3\"]\n  }],\n  \"scenarioDescriptor\": {\"scenarioID\": \"defi_eth_phase0_scn\", \"scenarioType\": \"scenario\"},\n  \"simulateTo\": \"2025-02-01T00:00:00\",\n  \"monitoringTimes\": []\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Asset-Only Run',function(){",
                "  pm.response.to.have.status(200);",
                "  var data = pm.response.json();",
                "  var c = data[0];",
                "  var events = c.events || [];",
                "  ",
                "  var ppEvents = events.filter(e => e.type === 'PP' && Math.abs(e.payoff || 0) > 0.01);",
                "  var ethAdditions = [];",
                "  var usdPayoffs = [];",
                "  ",
                "  ppEvents.forEach(function(pp){",
                "    usdPayoffs.push({time: pp.time, amountUSD: Math.abs(pp.payoff)});",
                "    var ds = pp.time.substring(0,10);",
                "    var ethPrice = ds === '2025-01-12' ? 2810 : ds === '2025-01-17' ? 2480 : 2750;",
                "    var ethAdd = Math.abs(pp.payoff) / ethPrice;",
                "    ethAdditions.push({time: pp.time, amountETH: ethAdd, priceUSD: ethPrice});",
                "  });",
                "  ",
                "  pm.collectionVariables.set('derived_usd_payoffs', JSON.stringify(usdPayoffs));",
                "  pm.collectionVariables.set('derived_eth_additions', JSON.stringify(ethAdditions));",
                "  ",
                "  console.log('✅ Phase 0 complete: '+ppEvents.length+' PP events captured');",
                "  console.log('  USD payoffs: '+usdPayoffs.length);",
                "  console.log('  ETH additions: '+ethAdditions.length);",
                "  ppEvents.forEach((p,i) => console.log('    PP#'+(i+1)+' '+p.time+': $'+p.payoff.toFixed(2)));",
                "});"
              ]
            }
          }]
        }
      ]
    },
    {
      "name": "══ PHASE 3: Register Derived SCF Models ══",
      "item": [
        {
          "name": "3.1 Register All Derived Models",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {
              "raw": "http://{{actus_risk_host}}/addReferenceIndex",
              "host": ["{{actus_risk_host}}"],
              "protocol": "http",
              "path": ["addReferenceIndex"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\"riskFactorID\":\"DUMMY_RI\",\"marketObjectCode\":\"DUMMY\",\"base\":1.0,\"data\":[{\"time\":\"2025-01-01T00:00:00\",\"value\":1}]}"
            }
          },
          "event": [{
            "listen": "prerequest",
            "script": {
              "exec": [
                "var riskHost = pm.collectionVariables.get('actus_risk_host');",
                "var base = 'http://'+riskHost;",
                "",
                "var usdPayoffs = pm.collectionVariables.get('derived_usd_payoffs');",
                "var ethAdditions = pm.collectionVariables.get('derived_eth_additions');",
                "",
                "if(!usdPayoffs || !ethAdditions){",
                "  throw new Error('Phase 0 data missing — run Phase 2 first');",
                "}",
                "",
                "var usdData = JSON.parse(usdPayoffs);",
                "pm.sendRequest({",
                "  url: base+'/addScheduledCashFlowModel',",
                "  method: 'POST',",
                "  header: {'Content-Type':'application/json'},",
                "  body: {mode:'raw', raw:JSON.stringify({",
                "    riskFactorId: 'scf_usd_payoffs',",
                "    cashFlowSchedule: usdData,",
                "    monitoringEventTimes: usdData.map(d => d.time)",
                "  })}",
                "},function(e,r){console.log(e?'❌ scf_usd_payoffs':'✅ scf_usd_payoffs: '+usdData.length+' USD prepayments');});",
                "",
                "var ethData = JSON.parse(ethAdditions).map(e => ({time:e.time, amountUSD:e.amountETH * e.priceUSD}));",
                "pm.sendRequest({",
                "  url: base+'/addScheduledCashFlowModel',",
                "  method: 'POST',",
                "  header: {'Content-Type':'application/json'},",
                "  body: {mode:'raw', raw:JSON.stringify({",
                "    riskFactorId: 'scf_eth_additions',",
                "    cashFlowSchedule: ethData,",
                "    monitoringEventTimes: ethData.map(d => d.time)",
                "  })}",
                "},function(e,r){console.log(e?'❌ scf_eth_additions':'✅ scf_eth_additions: '+ethData.length+' ETH collateral adds');});",
                "",
                "pm.sendRequest({",
                "  url: base+'/addScheduledCashFlowModel',",
                "  method: 'POST',",
                "  header: {'Content-Type':'application/json'},",
                "  body: {mode:'raw', raw:JSON.stringify({",
                "    riskFactorId: 'scf_loan_disbursement',",
                "    cashFlowSchedule: [{time:'2025-01-01T00:00:00', amountUSD:9000}],",
                "    monitoringEventTimes: ['2025-01-01T00:00:00']",
                "  })}",
                "},function(e,r){console.log(e?'❌ scf_loan_disbursement':'✅ scf_loan_disbursement: $9000 initial loan');});",
                "",
                "console.log('Phase 3: 3 SCF models registered');"
              ]
            }
          }],
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["pm.test('Derived Models',function(){pm.response.to.have.status(200);console.log('✅ Phase 3 complete: SCF models registered');});"]
            }
          }]
        }
      ]
    },
