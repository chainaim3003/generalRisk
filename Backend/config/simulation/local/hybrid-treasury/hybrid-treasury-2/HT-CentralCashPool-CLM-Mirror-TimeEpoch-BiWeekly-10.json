        "    var np = 8000000;",
        "    (pam.events||pam.cashFlows||[]).forEach(function(e){",
        "      var typ = e.type||e.eventType||'';",
        "      var pay = Math.round(e.payoff||e.amount||0);",
        "      var t   = (e.time||'').toString().substring(0,10);",
        "      if ((typ==='PP'||typ==='PRD') && Math.abs(pay) > 0.01) {",
