    {
      "name": "04 Derive & Register Risk Factors from Contracts",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// ═══════════════════════════════════════════════════════════════════",
              "// SINGLE SOURCE OF TRUTH — T-Bill + CLM contract definitions",
              "// $8M pool: CLMs $2M total, T-Bills $988,113, residual $5,011,887",
              "// ═══════════════════════════════════════════════════════════════════",
              "var tbills = [",
              "  { id: 'TBILL-3mo-400K', maturityDate: '2026-06-01T00:00:00', face: 400000, purchasePrice: 396320 },",
              "  { id: 'TBILL-4mo-350K', maturityDate: '2026-07-01T00:00:00', face: 350000, purchasePrice: 345679 },",
              "  { id: 'TBILL-5mo-250K', maturityDate: '2026-08-01T00:00:00', face: 250000, purchasePrice: 246114 }",
              "];",
              "",
              "// ── CLM parameters ───────────────────────────────────────────────",
              "var clmLendingNP   = 1000000;",
              "var clmLendingRate = 0.03;",
              "var clmInterestMo  = clmLendingNP * clmLendingRate / 12;  // $2,500/month",
              "var clmInterestBiWk = clmInterestMo / 2;                   // $1,250/biweek",
              "",
              "// ── Derive TBILL_MAT_01 ──────────────────────────────────────────",
              "var tbillMatData = [{ time: '2026-03-01T00:00:00', value: 0 }];",
              "tbills.forEach(function(t) {",
              "  tbillMatData.push({ time: t.maturityDate, value: t.face });",
              "});",
              "",
              "// ── Derive scf schedule (maturity inflows only) ──────────────────",
              "var scfSchedule = [];",
              "var scfMonTimes = [];",
              "tbills.forEach(function(t) {",
              "  scfSchedule.push({ time: t.maturityDate, amountUSD: t.face });",
              "  scfMonTimes.push(t.maturityDate);",
              "});",
              "",
              "// ── Derive OUTFLOWS_01 (ops scaled for $8M portfolio) ────────────",
              "// Ops base scaled ~2.67x from v13 $3M values. CLM interest added.",
              "var opsBase = [",
              "  { time: '2026-03-01T00:00:00', ops: 75000  },",
              "  { time: '2026-03-31T00:00:00', ops: 75000  },",
              "  { time: '2026-04-30T00:00:00', ops: 90000  },",
              "  { time: '2026-05-31T00:00:00', ops: 115000 },",
              "  { time: '2026-06-15T00:00:00', ops: 235000 },",
              "  { time: '2026-06-30T00:00:00', ops: 355000 },",
              "  { time: '2026-07-15T00:00:00', ops: 155000 },",
              "  { time: '2026-07-31T00:00:00', ops: 115000 },",
              "  { time: '2026-08-31T00:00:00', ops: 75000  }",
              "];",
              "var outflowsData = opsBase.map(function(o) {",
              "  return { time: o.time, value: o.ops + clmInterestBiWk };",
              "});",
              "",
              "// ── Summary log ──────────────────────────────────────────────────",
              "var totalFace     = tbills.reduce(function(s,t){ return s+t.face; }, 0);",
              "var totalPurchase = tbills.reduce(function(s,t){ return s+t.purchasePrice; }, 0);",
              "var residual      = 8000000 - 2000000 - totalPurchase;",
              "console.log('[Derive] Pool=$8M  CLMs=$2M  T-Bills=$' + totalPurchase.toLocaleString() + '  Residual=$' + residual.toLocaleString());",
              "console.log('[Derive] T-Bill yield=$' + (totalFace-totalPurchase).toLocaleString() + '  CLM interest/biweek=$' + clmInterestBiWk);",
              "console.log('[Derive] Alloc bands: min=20% target=25% max=30%');",
              "console.log('[Derive] Breach fires at ~$64K BTC (May-15 @$68K in price path)');",
              "console.log('[Derive] TBILL_MAT_01: ' + JSON.stringify(tbillMatData));",
              "console.log('[Derive] scf: ' + JSON.stringify(scfSchedule));",
              "console.log('[Derive] OUTFLOWS_01: ' + JSON.stringify(outflowsData));",
              "",
              "// ── POST all three ────────────────────────────────────────────────",
              "var host = pm.collectionVariables.get('model_host') || 'localhost';",
              "var port = pm.collectionVariables.get('model_port') || '8082';",
              "var base = 'http://' + host + ':' + port;",
              "",
              "pm.sendRequest({",
              "  url: base + '/addReferenceIndex', method: 'POST',",
              "  header: {'Content-Type': 'application/json'},",
              "  body: { mode: 'raw', raw: JSON.stringify({",
              "    riskFactorID: 'OUTFLOWS_01', marketObjectCode: 'PROJECTED_OUTFLOWS',",
              "    base: 1.0, data: outflowsData",
              "  })}",
              "}, function(err1, res1) {",
              "  var s1 = err1 ? 'ERR:'+err1 : String(res1.code);",
              "  pm.environment.set('derive_outflows_status', s1);",
              "  console.log('[Derive] OUTFLOWS_01 POST: ' + s1);",
              "",
              "  pm.sendRequest({",
              "    url: base + '/addReferenceIndex', method: 'POST',",
              "    header: {'Content-Type': 'application/json'},",
              "    body: { mode: 'raw', raw: JSON.stringify({",
              "      riskFactorID: 'TBILL_MAT_01', marketObjectCode: 'TBILL_MATURITY_SCHEDULE',",
              "      base: 1.0, data: tbillMatData",
              "    })}",
              "  }, function(err2, res2) {",
              "    var s2 = err2 ? 'ERR:'+err2 : String(res2.code);",
              "    pm.environment.set('derive_tbillmat_status', s2);",
              "    console.log('[Derive] TBILL_MAT_01 POST: ' + s2);",
              "",
              "    pm.sendRequest({",
              "      url: base + '/addScheduledCashFlowModel', method: 'POST',",
              "      header: {'Content-Type': 'application/json'},",
              "      body: { mode: 'raw', raw: JSON.stringify({",
              "        riskFactorId: 'scf_tbill_flows_01',",
              "        cashFlowSchedule: scfSchedule,",
              "        monitoringEventTimes: scfMonTimes",
              "      })}",
              "    }, function(err3, res3) {",
              "      var s3 = err3 ? 'ERR:'+err3 : String(res3.code);",
              "      pm.environment.set('derive_scf_status', s3);",
              "      console.log('[Derive] scf_tbill_flows_01 POST: ' + s3);",
              "    });",
              "  });",
              "});"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('04 server reachable for derived POST', function() {",
              "  pm.expect(pm.response.code).to.be.oneOf([200,404,405]);",
              "});",
              "var s1 = pm.environment.get('derive_outflows_status') || '(pending)';",
              "var s2 = pm.environment.get('derive_tbillmat_status') || '(pending)';",
              "var s3 = pm.environment.get('derive_scf_status')      || '(pending)';",
              "pm.test('04 OUTFLOWS_01 derived+posted (200)',      function() { pm.expect(s1).to.equal('200'); });",
              "pm.test('04 TBILL_MAT_01 derived+posted (200)',     function() { pm.expect(s2).to.equal('200'); });",
              "pm.test('04 scf_tbill_flows_01 derived+posted (200)', function() { pm.expect(s3).to.equal('200'); });",
              "console.log('04 Derived: OUTFLOWS=' + s1 + ' TBILL_MAT=' + s2 + ' SCF=' + s3);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {"raw": "http://localhost:8082/", "protocol": "http", "host": ["localhost"], "port": "8082", "path": [""]},
        "description": "Prerequest derives OUTFLOWS_01, TBILL_MAT_01, scf_tbill_flows_01 from T-Bill definitions and POSTs all three. GET ping is a no-op."
      },
      "response": []
    },
