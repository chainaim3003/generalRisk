                  "",
                  "var dayNum = epoch + 1;",
                  "var br = BR[epoch], lq = LQ[epoch], peg = PEG[epoch], mr = MR[epoch];",
                  "",
                  "if (epoch === 0) {",
                  "    console.log('═'.repeat(70));",
                  "    console.log('HOLDER PORTFOLIO: USD ↔ USDC based on Published Risk Metrics');",
                  "    console.log('  Starting: $' + CFG.initialUsd.toLocaleString() + ' USD, $0 USDC');",
                  "    console.log('  Target: $' + CFG.targetUsdc.toLocaleString() + ' USDC');",
                  "    console.log('  Decision: Read risk indices → Buy/Sell USDC');",
                  "    console.log('═'.repeat(70));",
                  "}",
                  "",
                  "// Simple decision logic based on published risk metrics",
                  "var action = 'HOLD';",
                  "var amount = 0;",
                  "",
                  "// GOOD metrics = all near zero",
                  "var isGood = (br < 0.05 && lq < 0.10 && peg < 0.01 && mr < 0.10);",
                  "// BAD metrics = any significant elevation",
                  "var isBad = (br > 0.10 || lq > 0.30 || peg > 0.02 || mr > 0.20);",
                  "",
                  "if (isGood && usdc < CFG.targetUsdc && usd > 1000) {",
                  "    // Deploy to USDC",
                  "    var gap = CFG.targetUsdc - usdc;",
                  "    amount = Math.min(Math.round(usd * CFG.deployPct), Math.round(gap));",
                  "    if (amount >= 1000) {",
                  "        usd -= amount;",
                  "        usdc += amount;",
                  "        action = 'BUY_USDC';",
                  "    } else {",
                  "        amount = 0;",
                  "    }",
                  "} else if (isBad && usdc > 0) {",
                  "    // Exit to USD",
                  "    amount = usdc;",
                  "    usd += usdc;",
                  "    usdc = 0;",
                  "    action = 'SELL_USDC';",
                  "}",
                  "",
                  "var total = Math.round(usd + usdc);",
                  "var status = isGood ? '✅ GOOD' : (isBad ? '⚠️ RISKY' : '━ HOLD');",
                  "",
                  "var snap = {",
                  "    day: dayNum,",
                  "    usd: Math.round(usd),",
                  "    usdc: Math.round(usdc),",
                  "    total: total,",
                  "    action: action,",
                  "    amount: Math.round(amount),",
                  "    br: br,",
                  "    lq: lq,",
                  "    peg: peg,",
                  "    mr: mr,",
                  "    status: status",
                  "};",
                  "history.push(snap);",
                  "",
                  "pm.collectionVariables.set('rt_usd', String(Math.round(usd)));",
                  "pm.collectionVariables.set('rt_usdc', String(Math.round(usdc)));",
                  "pm.collectionVariables.set('rt_epoch', String(epoch + 1));",
                  "pm.collectionVariables.set('rt_history', JSON.stringify(history));",
                  "",
                  "var act = action !== 'HOLD' ? ' ' + action + '($' + Math.round(amount) + ')' : '';",
                  "console.log('Day ' + String(dayNum).padStart(2) + ': USD=$' + Math.round(usd).toLocaleString().padStart(7) +",
                  "    ' USDC=$' + Math.round(usdc).toLocaleString().padStart(7) + ' Total=$' + total.toLocaleString().padStart(7) +",
                  "    act.padEnd(20) + status + '  [BR=' + br.toFixed(2) + ' LQ=' + lq.toFixed(2) +",
                  "    ' PEG=' + peg.toFixed(3) + ' MR=' + mr.toFixed(2) + ']');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var epoch = parseInt(pm.collectionVariables.get('rt_epoch') || '0');",
                  "var NDAYS = 45;",
                  "pm.test('Day ' + epoch + '/' + NDAYS, function() { pm.expect(epoch).to.be.at.most(NDAYS); });",
                  "if (epoch < NDAYS) { pm.execution.setNextRequest('2.1 Daily Portfolio Manager'); }",
                  "else { console.log('━'.repeat(70)); pm.execution.setNextRequest('3.1 Final Summary'); }"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "═ PHASE 3: Final Summary ═",
      "item": [
        {
          "name": "3.1 Final Summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://{{actus_risk_host}}/",
              "host": ["{{actus_risk_host}}"],
              "path": [""]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "var history = JSON.parse(pm.collectionVariables.get('rt_history') || '[]');",
                  "var INIT = parseFloat(pm.collectionVariables.get('cfg_initial_usd'));",
                  "",
                  "console.log('═'.repeat(70));",
                  "console.log('FINAL SUMMARY: Holder Portfolio (45 days)');",
                  "console.log('═'.repeat(70));",
                  "console.log('Day  USD         USDC        Total       Action               Risk Metrics');",
                  "console.log('─'.repeat(90));",
                  "",
                  "var buys = 0, sells = 0;",
                  "history.forEach(function(s) {",
                  "    var u = ('$' + s.usd.toLocaleString()).padEnd(12);",
                  "    var c = ('$' + s.usdc.toLocaleString()).padEnd(12);",
                  "    var t = ('$' + s.total.toLocaleString()).padEnd(12);",
                  "    var act = '';",
                  "    if (s.action === 'BUY_USDC') { act = 'BUY($' + s.amount.toLocaleString() + ')'; buys++; }",
                  "    else if (s.action === 'SELL_USDC') { act = 'SELL($' + s.amount.toLocaleString() + ')'; sells++; }",
                  "    act = act.padEnd(21);",
                  "    var metrics = 'BR=' + s.br.toFixed(2) + ' LQ=' + s.lq.toFixed(2) + ' PEG=' + s.peg.toFixed(3) + ' MR=' + s.mr.toFixed(2);",
                  "    console.log(String(s.day).padStart(3) + '  ' + u + c + t + act + metrics);",
                  "});",
                  "",
                  "var last = history[history.length - 1] || {};",
                  "console.log('─'.repeat(90));",
                  "console.log('FINAL: USD=$' + last.usd.toLocaleString() + ' USDC=$' + last.usdc.toLocaleString() + ' Total=$' + last.total.toLocaleString());",
                  "console.log('  Portfolio: ' + ((last.total / INIT) * 100).toFixed(1) + '% | Buys: ' + buys + ' | Sells: ' + sells);",
                  "console.log('  Result: ' + (last.total >= INIT ? '✅ Capital Preserved' : '⚠️ Loss'));",
                  "console.log('═'.repeat(70));",
                  "",
                  "pm.test('Tracking complete', function() { pm.expect(history.length).to.equal(45); });",
                  "pm.test('Capital preserved', function() { pm.expect(last.total).to.be.within(INIT * 0.95, INIT * 1.05); });",
                  "",
                  "// Reset for next run",
                  "pm.collectionVariables.set('rt_epoch', '0');",
                  "pm.collectionVariables.set('rt_usd', pm.collectionVariables.get('cfg_initial_usd'));",
                  "pm.collectionVariables.set('rt_usdc', '0');",
                  "pm.collectionVariables.set('rt_history', '[]');"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
