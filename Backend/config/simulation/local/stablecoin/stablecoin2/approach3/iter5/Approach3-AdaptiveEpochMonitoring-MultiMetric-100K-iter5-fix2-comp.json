        {
          "name": "Setup 1: Store peg-deviation + rate-shock curves",
          "request": {"method":"GET","header":[],"url":{"raw":"http://{{actus_sim_host}}/","host":["{{actus_sim_host}}"],"path":[""]}},
          "event": [
            {"listen":"prerequest","script":{"type":"text/javascript","exec":[
              "// COMPRESSED peg curve: WATCH(0.1%) h=6, ELEVATED(0.3%) h=12, CRITICAL(1%) h=22, peak 2.5% h=36, clear h=54",
              "var pegCurve = [{h:0,v:0.0005},{h:6,v:0.001},{h:12,v:0.003},{h:18,v:0.008},{h:24,v:0.013},{h:30,v:0.02},{h:36,v:0.025},{h:42,v:0.02},{h:48,v:0.014},{h:54,v:0.008},{h:60,v:0.003},{h:66,v:0.001},{h:72,v:0.0003}];",
              "// Rate shock deliberately mild (max 8bps) so MtM stays >= face. Backing NOT the halt trigger.",
              "var rateCurve = [{h:0,v:0},{h:12,v:1},{h:24,v:4},{h:36,v:8},{h:42,v:7},{h:48,v:5},{h:54,v:3},{h:60,v:1},{h:72,v:0}];",
              "pm.environment.set('curve_peg',  JSON.stringify(pegCurve));",
              "pm.environment.set('curve_rate', JSON.stringify(rateCurve));",
              "console.log('\u2705 [COMP] Setup 1: peg(peak 2.5% h=36) + rate(max 8bps) stored');"
            ]}},
            {"listen":"test","script":{"type":"text/javascript","exec":[
              "pm.test('Setup 1 OK', function(){ pm.expect(pm.response.code).to.be.oneOf([200,404,405]); pm.expect(pm.environment.get('curve_peg')).to.not.be.empty; });"
            ]}}
          ]
        },
        {
