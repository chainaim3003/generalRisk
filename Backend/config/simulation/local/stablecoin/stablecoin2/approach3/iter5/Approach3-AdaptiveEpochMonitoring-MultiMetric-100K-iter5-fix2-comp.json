          "  {id:'tbill-4wk-001',      type:'tbill',     face:10000, hqla:'L1',  quality:100,",
          "   dealDate:'2026-02-10T00:00:00', maturityDate:'2026-03-05T00:00:00', duration:0.019},",
          "  {id:'tbill-13wk-001',     type:'tbill',     face:32000, hqla:'L1',  quality:100,",
          "   dealDate:'2026-01-20T00:00:00', maturityDate:'2026-04-21T00:00:00', duration:0.134},",
          "  {id:'tbill-26wk-001',     type:'tbill',     face:26000, hqla:'L1',  quality:100,",
          "   dealDate:'2025-12-15T00:00:00', maturityDate:'2026-06-15T00:00:00', duration:0.285},",
