          "  {id:'defi-yield-001',     type:'defi',      face:4000,  hqla:'L2B', quality:60,",
          "   dealDate:'2026-02-01T00:00:00', maturityDate:'2026-06-01T00:00:00', duration:0.247}",
          "];",
