          "var proxL = liquidityRatio<CFG.liquidityThresh*1.1 && Math.abs(liquidityRatio-CFG.liquidityThresh)/CFG.liquidityThresh<CFG.proxPct;",
          "var nearT = proxB||proxL;",
          "var newCad;",
          "if      (ewSignals>=3||pegDev>=CFG.pegCritical||liquidityRatio<0.10||mintStatus==='HALTED') newCad='CRITICAL';",
          "else if (ewSignals>=1||pegDev>=CFG.pegElevated||nearT||trendSignal!=='STABLE')              newCad='ELEVATED';",
          "else if (pegDev>=CFG.pegWatch||depositDmd>5000)                                             newCad='WATCH';",
          "else                                                                                         newCad='NORMAL';",
          "var rank={NORMAL:0,WATCH:1,ELEVATED:2,CRITICAL:3};",
          "if (rank[newCad] < rank[prevCad]) {",
