    {
      "name": "Adaptive Epoch Evaluator",
      "description": "fix2-comp: pm.sendRequest() to ACTUS /eventsBatch. 11 JS behavioral models. Compressed 72h lifecycle. defi quality window remapped to h=24-48.",
      "request": {"method":"GET","header":[],"url":{"raw":"http://{{actus_sim_host}}/","host":["{{actus_sim_host}}"],"path":[""]}},
      "event": [
        {"listen":"prerequest","script":{"type":"text/javascript","exec":[
          "var epochNum = parseInt(pm.environment.get('epoch_num') || '0') + 1;",
          "pm.environment.set('epoch_num', String(epochNum));",
          "var simHour  = parseFloat(pm.environment.get('sim_hour') || '0');",
          "var portfolio = JSON.parse(pm.environment.get('portfolio') || '[]');",
          "var baseMs = new Date('2026-03-03T00:00:00Z').getTime();",
          "var nowMs  = baseMs + simHour * 3600000;",
