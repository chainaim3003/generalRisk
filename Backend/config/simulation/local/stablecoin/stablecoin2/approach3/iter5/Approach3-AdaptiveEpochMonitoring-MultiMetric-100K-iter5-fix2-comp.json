        {"listen":"test","script":{"type":"text/javascript","exec":[
          "// 11 BEHAVIORAL MODELS - all pure JS, no risksrv3 needed",
          "var simHour    = parseFloat(pm.environment.get('sim_hour')       || '0');",
          "var epochNum   = parseInt(pm.environment.get('epoch_num')        || '1');",
          "var cadence    = pm.environment.get('cadence')                   || 'NORMAL';",
          "var epochDT    = pm.environment.get('epoch_datetime')            || '';",
          "var portfolio  = JSON.parse(pm.environment.get('portfolio')      || '[]');",
          "var tokenSup   = parseFloat(pm.environment.get('token_supply')   || '100000');",
          "var actusErr   = pm.environment.get('actus_epoch_error')         || '';",
          "var CFG = {",
          "    maxEpochs:       parseInt(pm.environment.get('cfg_maxEpochs')         || '60'),",
          "    simEndHours:     parseFloat(pm.environment.get('cfg_simEndHours')     || '72'),",
          "    normalHrs:       parseFloat(pm.environment.get('cfg_normalHrs')       || '6'),",
          "    watchHrs:        parseFloat(pm.environment.get('cfg_watchHrs')        || '3'),",
          "    elevatedHrs:     parseFloat(pm.environment.get('cfg_elevatedHrs')     || '2'),",
          "    criticalHrs:     parseFloat(pm.environment.get('cfg_criticalHrs')     || '1'),",
          "    backingThresh:   parseFloat(pm.environment.get('cfg_backingThresh')   || '1.00'),",
          "    liquidityThresh: parseFloat(pm.environment.get('cfg_liquidityThresh') || '0.20'),",
          "    qualityThresh:   parseFloat(pm.environment.get('cfg_qualityThresh')   || '70'),",
          "    ewHalt:          parseInt(pm.environment.get('cfg_ewHalt')            || '4'),",
          "    pegWatch:        parseFloat(pm.environment.get('cfg_pegWatch')        || '0.001'),",
          "    pegElevated:     parseFloat(pm.environment.get('cfg_pegElevated')     || '0.003'),",
          "    pegCritical:     parseFloat(pm.environment.get('cfg_pegCritical')     || '0.010'),",
          "    deescN:          parseInt(pm.environment.get('cfg_deescN')            || '2'),",
          "    trendWin:        parseInt(pm.environment.get('cfg_trendWin')          || '2'),",
          "    proxPct:         parseFloat(pm.environment.get('cfg_proxPct')         || '0.05')",
          "};",
          "function interp(curve, h) {",
          "    if (h <= curve[0].h) return curve[0].v;",
          "    var last = curve[curve.length-1];",
          "    if (h >= last.h) return last.v;",
          "    for (var i=0; i<curve.length-1; i++) {",
          "        if (h >= curve[i].h && h <= curve[i+1].h) {",
          "            var t = (h-curve[i].h)/(curve[i+1].h-curve[i].h);",
          "            return curve[i].v + t*(curve[i+1].v-curve[i].v);",
          "        }",
          "    } return last.v;",
          "}",
          "var pegDev      = interp(JSON.parse(pm.environment.get('curve_peg')            || '[]'), simHour);",
          "var rateShockBps= interp(JSON.parse(pm.environment.get('curve_rate')           || '[]'), simHour);",
          "var bankStress  = interp(JSON.parse(pm.environment.get('curve_bankStress')     || '[]'), simHour);",
          "var depositDmd  = interp(JSON.parse(pm.environment.get('curve_deposit')        || '[]'), simHour);",
          "var curveImbal  = interp(JSON.parse(pm.environment.get('curve_curveImbalance') || '[]'), simHour);",
          "var orderbook   = interp(JSON.parse(pm.environment.get('curve_orderbook')      || '[]'), simHour);",
          "var cexOutflow  = interp(JSON.parse(pm.environment.get('curve_cexOutflow')     || '[]'), simHour);",
          "var sentiment   = interp(JSON.parse(pm.environment.get('curve_sentiment')      || '[]'), simHour);",
          "var actusData   = JSON.parse(pm.environment.get('actus_epoch_data') || '[]');",
          "var results     = Array.isArray(actusData) ? actusData : Object.values(actusData);",
          "var pLookup     = {};",
          "portfolio.forEach(function(p){ pLookup[p.id] = p; });",
          "var totalFace=0, totalMtM=0, cashMtM=0, wqSum=0, contractCount=0, assetBD={};",
          "function processInstrument(id, face, pi) {",
          "    contractCount++;",
          "    var dur = pi.duration || 0.003;",
          "    var mtm = face * (1 - dur * rateShockBps / 10000);",
          "    var q   = pi.quality || 100;",
          "    if (pi.type==='commpaper') q = Math.max(50, 85*(1-bankStress*0.5));",
          "    // defi quality: degrades during crisis h=24-48, partial recovery h=48-60",
          "    if (pi.type==='defi') q = simHour>=24&&simHour<=48?35:simHour>48&&simHour<=60?45:60;",
          "    assetBD[id] = {face:face, mtm:mtm, quality:q, type:pi.type||'cash'};",
          "    totalFace += face; totalMtM += mtm; wqSum += mtm*q;",
          "    if (pi.type==='cash') cashMtM += mtm;",
          "}",
          "if (results.length > 0) {",
          "    results.forEach(function(c){",
          "        var cid = c.contractId || c.contractID || 'unknown';",
          "        var events = c.events || [];",
          "        var notional = 0;",
          "        events.forEach(function(e){",
          "            if (e.type==='IP'  && e.nominalValue>0) notional=e.nominalValue;",
          "            if (e.type==='IED') notional=Math.abs(e.payoff||e.nominalValue||0);",
          "        });",
          "        if (!notional) events.forEach(function(e){ if(e.type==='MD'&&e.payoff>0) notional=e.payoff; });",
          "        if (!notional) { var pp=pLookup[cid]; if(pp) notional=pp.face; }",
          "        var pi = pLookup[cid] || {type:'cash',duration:0.003,quality:100};",
          "        processInstrument(cid, notional, pi);",
          "    });",
          "} else {",
          "    if (actusErr) console.warn('[Ep'+epochNum+'] JS-fallback: ' + actusErr);",
          "    portfolio.forEach(function(c){ processInstrument(c.id, c.face, c); });",
          "}",
          "var avgQuality    = totalMtM > 0 ? wqSum/totalMtM : 0;",
          "var liquidityRatio= cashMtM  / tokenSup;",
          "var backingMtM    = totalMtM / tokenSup;",
          "var dailyRedmRate = pegDev>=0.10?0.52:pegDev>=0.05?0.285:pegDev>=0.03?0.142:pegDev>=0.01?0.057:pegDev>=0.005?0.023:0.005;",
          "var hourlyRedm    = tokenSup * dailyRedmRate / 24;",
          "var nearestMatDays = 999;",
          "var baseMs = new Date('2026-03-03T00:00:00Z').getTime();",
          "portfolio.forEach(function(c){",
          "    if (c.type!=='cash'){ var d=(new Date(c.maturityDate).getTime()-baseMs-simHour*3600000)/86400000; if(d>0&&d<nearestMatDays) nearestMatDays=d; }",
          "});",
          "var ladderAction = pegDev<0.005?'ROLL':nearestMatDays<3?'KEEP_CASH':'HOLD';",
          "var hhi = 0;",
          "Object.keys(assetBD).forEach(function(k){ if(totalMtM>0){ var s=assetBD[k].mtm/totalMtM; hhi+=s*s; } });",
          "var wamN=0, wamD=0;",
          "portfolio.forEach(function(c){ if(c.type!=='cash'){ var d=Math.max(0,(new Date(c.maturityDate).getTime()-baseMs-simHour*3600000)/86400000); wamN+=c.face*d; wamD+=c.face; } });",
          "var wam = wamD>0 ? wamN/wamD : 0;",
          "var ewSignals=0;",
