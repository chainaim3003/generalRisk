        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": {"raw": "http://localhost:8082/addScenario", "protocol": "http", "host": ["localhost:8082"], "path": ["addScenario"]},
        "body": {
          "mode": "raw",
          "raw": "{\"scenarioID\":\"sc_ml_iter5_scn01\",\"riskFactorDescriptors\":[{\"riskFactorID\":\"SC_PEG_RISK_I5\",\"riskFactorType\":\"ReferenceIndex\"},{\"riskFactorID\":\"ml_sc_i5\",\"riskFactorType\":\"MaturityLadderModel\"}]}",
          "options": {"raw": {"language": "json"}}
        }
      },
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
        "pm.test('MaturityLadder iter5 scenario created', function(){",
        "    pm.response.to.have.status(200);",
        "    pm.expect(pm.response.text()).to.include('Successfully');",
        "    console.log('\\u2705 sc_ml_iter5_scn01: 1 composite index + MaturityLadderModel');",
        "});"
      ]}}]
    },
    {
      "name": "4a. Verify MaturityLadderModel iter5",
      "request": {"method": "GET", "header": [], "url": {"raw": "http://localhost:8082/findMaturityLadderModel/ml_sc_i5", "protocol": "http", "host": ["localhost:8082"], "path": ["findMaturityLadderModel", "ml_sc_i5"]}},
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
        "pm.test('MaturityLadderModel iter5 verified', function(){",
        "    pm.response.to.have.status(200);",
        "    var d=pm.response.json();",
        "    pm.expect(d.riskFactorId).to.eql('ml_sc_i5');",
        "    pm.expect(d.pegRiskScoreMOC).to.eql('PEG_RISK_SCORE');",
        "    console.log('\\u2705 ml_sc_i5: pegRiskScoreMOC='+d.pegRiskScoreMOC);",
        "});"
      ]}}]
    },
    {
      "name": "4b. Verify Scenario",
      "request": {"method": "GET", "header": [], "url": {"raw": "http://localhost:8082/findScenario/sc_ml_iter5_scn01", "protocol": "http", "host": ["localhost:8082"], "path": ["findScenario", "sc_ml_iter5_scn01"]}},
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
        "pm.test('Scenario verified', function(){",
        "    var types=pm.response.json().riskFactorDescriptors.map(function(d){return d.riskFactorType;});",
        "    pm.expect(types).to.include('MaturityLadderModel');",
        "    console.log('\\u2705 Descriptors: '+JSON.stringify(types));",
        "});"
      ]}}]
    },
    {
      "name": "5. Run MaturityLadder iter5 Simulation — 7-instrument PAM portfolio",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "url": {"raw": "http://localhost:8083/rf2/scenarioSimulation", "protocol": "http", "host": ["localhost:8083"], "path": ["rf2", "scenarioSimulation"]},
        "body": {
          "mode": "raw",
          "raw": "{\"contracts\":[{\"contractType\":\"PAM\",\"statusDate\":\"2026-03-02T00:00:00\",\"contractRole\":\"RPA\",\"contractID\":\"tbill-4wk-001\",\"contractDealDate\":\"2026-02-10T00:00:00\",\"initialExchangeDate\":\"2026-02-10T00:00:00\",\"maturityDate\":\"2026-03-21T00:00:00\",\"notionalPrincipal\":10000,\"nominalInterestRate\":0.0,\"currency\":\"USD\",\"dayCountConvention\":\"A365\",\"stablecoinModels\":[\"ml_sc_i5\"]},{\"contractType\":\"PAM\",\"statusDate\":\"2026-03-02T00:00:00\",\"contractRole\":\"RPA\",\"contractID\":\"tbill-13wk-001\",\"contractDealDate\":\"2026-01-20T00:00:00\",\"initialExchangeDate\":\"2026-01-20T00:00:00\",\"maturityDate\":\"2026-04-21T00:00:00\",\"notionalPrincipal\":32000,\"nominalInterestRate\":0.0,\"currency\":\"USD\",\"dayCountConvention\":\"A365\",\"stablecoinModels\":[\"ml_sc_i5\"]},{\"contractType\":\"PAM\",\"statusDate\":\"2026-03-02T00:00:00\",\"contractRole\":\"RPA\",\"contractID\":\"tbill-26wk-001\",\"contractDealDate\":\"2025-12-15T00:00:00\",\"initialExchangeDate\":\"2025-12-15T00:00:00\",\"maturityDate\":\"2026-06-15T00:00:00\",\"notionalPrincipal\":26000,\"nominalInterestRate\":0.0,\"currency\":\"USD\",\"dayCountConvention\":\"A365\",\"stablecoinModels\":[\"ml_sc_i5\"]},{\"contractType\":\"PAM\",\"statusDate\":\"2026-03-02T00:00:00\",\"contractRole\":\"RPA\",\"contractID\":\"commpaper-90d-001\",\"contractDealDate\":\"2026-01-15T00:00:00\",\"initialExchangeDate\":\"2026-01-15T00:00:00\",\"maturityDate\":\"2026-04-15T00:00:00\",\"notionalPrincipal\":6000,\"nominalInterestRate\":0.0,\"currency\":\"USD\",\"dayCountConvention\":\"A365\",\"stablecoinModels\":[\"ml_sc_i5\"]}],\"scenarioDescriptor\":{\"scenarioID\":\"sc_ml_iter5_scn01\",\"scenarioType\":\"scenario\"},\"simulateTo\":\"2026-04-01T00:00:00\",\"monitoringTimes\":[]}",
          "options": {"raw": {"language": "json"}}
        }
      },
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
        "pm.test('MaturityLadder iter5 simulation (4 rollable instruments)', function(){",
        "    pm.response.to.have.status(200);",
        "    var data = pm.response.json();",
        "    console.log('');",
        "    console.log('\\u2554\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2557');",
        "    console.log('\\u2551  MATURITY LADDER MODEL (6.3) iter5 \\u2014 T-BILL ROLL DECISIONS           \\u2551');",
        "    console.log('\\u2551  Score: 0 \\u2192 50 peak \\u2192 1 | 4 rollable instruments                  \\u2551');",
        "    console.log('\\u2560\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2563');",
        "    console.log('\\u2551  Days 1-7:   score 0-12  \\u2192 NORMAL_ROLL (0.0) \\u2014 4wk rolls at maturity  \\u2551');",
        "    console.log('\\u2551  Days 8-10:  score 17-28 \\u2192 SHORTEN_TENOR (0.25) \\u2014 compress to 4wk   \\u2551');",
        "    console.log('\\u2551  Days 11-14: score 32-38 \\u2192 CASH_RETENTION (0.50) \\u2014 hold proceeds     \\u2551');",
        "    console.log('\\u2551  Days 15-17: score 45-50 \\u2192 EMERGENCY_LIQD (1.00) \\ud83d\\udea8 sell T-bills     \\u2551');",
        "    console.log('\\u2551  Day 18:     tbill-4wk matures \\u2192 score 44 \\u2192 CASH_RETENTION         \\u2551');",
        "    console.log('\\u2551  Day 19:     score 38 \\u2192 CASH_RETENTION \\u2192 SHORTEN_TENOR             \\u2551');",
        "    console.log('\\u2551  Days 22-30: score <15 \\u2192 NORMAL_ROLL \\u2705 \\u2014 new 4wk tbill purchased  \\u2551');",
        "    console.log('\\u255a\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u2550\\u255d');",
        "    pm.expect(data.length).to.equal(4);",
        "    var allOk = data.every(function(c){ return c.status==='Success'; });",
        "    pm.expect(allOk).to.be.true;",
        "    data.forEach(function(c){",
        "        var mrds = (c.events||[]).filter(function(e){ return e.type==='MRD'; });",
        "        var decisions = mrds.map(function(m){",
        "            return m.payoff===0?'ROLL':m.payoff===0.25?'SHORTEN':m.payoff===0.5?'CASH':'EMERGENCY';",
        "        });",
        "        var decCounts = {};",
        "        decisions.forEach(function(d){ decCounts[d]=(decCounts[d]||0)+1; });",
        "        console.log('  '+c.contractId+': '+JSON.stringify(decCounts));",
        "    });",
        "});",
        "pm.test('All 4 instruments processed', function(){ pm.expect(pm.response.json().length).to.equal(4); });"
      ]}}]
