    {
      "name": "C. Summary Report",
      "item": [
        {
          "name": "C1-Generate-Summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": "http://localhost:8083/"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "console.log('\\n' + '='.repeat(80));",
                  "console.log('CFO DECISION SUPPORT SUMMARY');",
                  "console.log('India Textile Exporter - GTAP \u03c3=3.8, Tariff 50%\u219218%');",
                  "console.log('='.repeat(80));",
                  "var A1 = pm.environment.get('A1_total') || 0;",
                  "var B1 = pm.environment.get('B1_total') || 0;",
                  "console.log('\\nRISK-ADJUSTED SOFR: Base 4.25% + Tariff 1.0% + Country 0.5% + WC 0.25% = 6.0% peak');",
                  "console.log('\\nA1 Floating (No Hedge): $' + A1.toFixed(0));",
                  "console.log('   - Full SOFR exposure 4.75%-6.0% + 2.5% spread');",
                  "console.log('   - Risk: HIGH volatility');",
                  "console.log('\\nB1 Fixed Swap 5.2%: $' + B1.toFixed(0));",
                  "console.log('   - Locked rate 7.7% (5.2% swap + 2.5% spread)');",
                  "console.log('   - Risk: LOW - budget certainty');",
                  "if(A1 > 0 && B1 > 0){",
                  "    var diff = A1 - B1;",
                  "    console.log('\\n' + '='.repeat(80));",
                  "    console.log('SWAP IMPACT: ' + (diff > 0 ? 'SAVES' : 'COSTS') + ' $' + Math.abs(diff).toFixed(0) + ' over 3 years');",
                  "    console.log('RECOMMENDATION: ' + (diff > 0 ? 'Execute swap - protects against rate spikes' : 'Monitor - rates may fall'));",
                  "}",
                  "console.log('='.repeat(80) + '\\n');"
                ]
              }
            }
          ]
        }
      ]
    }
