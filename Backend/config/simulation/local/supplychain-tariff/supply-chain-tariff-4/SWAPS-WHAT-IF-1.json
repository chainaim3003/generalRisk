            ],
            "url": "http://localhost:8083/eventsBatch",
            "body": {
              "mode": "raw",
              "raw": "{\"contracts\": [{\"contractType\": \"PAM\", \"contractID\": \"LOAN-FLOAT-B\", \"contractRole\": \"RPA\", \"contractDealDate\": \"2026-02-28T00:00:00\", \"statusDate\": \"2026-02-28T00:00:00\", \"initialExchangeDate\": \"2026-03-01T00:00:00\", \"maturityDate\": \"2029-03-01T00:00:00\", \"notionalPrincipal\": \"1000000\", \"currency\": \"USD\", \"dayCountConvention\": \"30E360\", \"nominalInterestRate\": \"0.0725\", \"cycleOfInterestPayment\": \"P3ML1\", \"cycleAnchorDateOfInterestPayment\": \"2026-06-01T00:00:00\", \"cycleOfRateReset\": \"P3ML1\", \"cycleAnchorDateOfRateReset\": \"2026-03-01T00:00:00\", \"marketObjectCodeOfRateReset\": \"CURRENT_RISK_ADJ_SOFR\", \"rateSpread\": \"0.025\", \"rateMultiplier\": \"1.0\"}, {\"contractType\": \"SWAPS\", \"contractID\": \"SWAP-FIXED-B\", \"contractRole\": \"PFL\", \"currency\": \"USD\", \"contractDealDate\": \"2026-02-28T00:00:00\", \"statusDate\": \"2026-02-28T00:00:00\", \"deliverySettlement\": \"D\", \"contractStructure\": [{\"object\": {\"contractType\": \"PAM\", \"contractID\": \"SWAP-B-FIXED\", \"contractDealDate\": \"2026-02-28T00:00:00\", \"initialExchangeDate\": \"2026-03-01T00:00:00\", \"currency\": \"USD\", \"statusDate\": \"2026-02-28T00:00:00\", \"notionalPrincipal\": \"1000000\", \"dayCountConvention\": \"30E360\", \"nominalInterestRate\": \"0.052\", \"maturityDate\": \"2029-03-01T00:00:00\", \"cycleAnchorDateOfInterestPayment\": \"2026-06-01T00:00:00\", \"cycleOfInterestPayment\": \"P3ML1\", \"premiumDiscountAtIED\": \"0\"}, \"referenceType\": \"CNT\", \"referenceRole\": \"FIL\"}, {\"object\": {\"contractType\": \"PAM\", \"contractID\": \"SWAP-B-FLOAT\", \"contractDealDate\": \"2026-02-28T00:00:00\", \"initialExchangeDate\": \"2026-03-01T00:00:00\", \"currency\": \"USD\", \"statusDate\": \"2026-02-28T00:00:00\", \"notionalPrincipal\": \"1000000\", \"dayCountConvention\": \"30E360\", \"nominalInterestRate\": \"0.0475\", \"maturityDate\": \"2029-03-01T00:00:00\", \"cycleAnchorDateOfInterestPayment\": \"2026-06-01T00:00:00\", \"cycleOfInterestPayment\": \"P3ML1\", \"cycleOfRateReset\": \"P3ML1\", \"cycleAnchorDateOfRateReset\": \"2026-03-01T00:00:00\", \"marketObjectCodeOfRateReset\": \"CURRENT_RISK_ADJ_SOFR\", \"rateMultiplier\": \"1.0\", \"rateSpread\": \"0.0\", \"premiumDiscountAtIED\": \"0\"}, \"referenceType\": \"CNT\", \"referenceRole\": \"SEL\"}]}], \"riskFactors\": [{\"marketObjectCode\": \"CURRENT_RISK_ADJ_SOFR\", \"base\": 1.0, \"data\": [{\"time\": \"2026-03-01T00:00:00\", \"value\": 0.0475}, {\"time\": \"2026-06-01T00:00:00\", \"value\": 0.0525}, {\"time\": \"2026-09-01T00:00:00\", \"value\": 0.0575}, {\"time\": \"2026-12-01T00:00:00\", \"value\": 0.06}, {\"time\": \"2027-03-01T00:00:00\", \"value\": 0.06}, {\"time\": \"2027-06-01T00:00:00\", \"value\": 0.0575}, {\"time\": \"2027-09-01T00:00:00\", \"value\": 0.055}, {\"time\": \"2027-12-01T00:00:00\", \"value\": 0.0525}, {\"time\": \"2028-03-01T00:00:00\", \"value\": 0.05}, {\"time\": \"2028-06-01T00:00:00\", \"value\": 0.0485}, {\"time\": \"2028-09-01T00:00:00\", \"value\": 0.0475}, {\"time\": \"2028-12-01T00:00:00\", \"value\": 0.0475}, {\"time\": \"2029-03-01T00:00:00\", \"value\": 0.0475}]}]}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('B1-Success', function(){ pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "var loanTotal = 0, swapTotal = 0;",
                  "data.forEach(function(c){",
                  "    if(c.contractID === 'LOAN-FLOAT-B'){",
                  "        c.events.filter(e => e.type === 'IP').forEach(e => { loanTotal += Math.abs(e.payoff); });",
                  "    } else if(c.contractID === 'SWAP-FIXED-B'){",
                  "        c.events.filter(e => e.type === 'IP').forEach(e => { swapTotal += e.payoff; });",
                  "    }",
                  "});",
                  "var total = loanTotal + swapTotal;",
                  "console.log('B1 Loan: $' + loanTotal.toFixed(0) + ', Swap: $' + swapTotal.toFixed(0) + ', Total: $' + total.toFixed(0));",
                  "pm.environment.set('B1_total', total);"
                ]
              }
            }
          ]
        }
      ]
