          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "http://localhost:8083/eventsBatch",
            "body": {
              "mode": "raw",
              "raw": "{\"contracts\": [{\"contractType\": \"PAM\", \"contractID\": \"LOAN-UNHEDGED-B\", \"contractRole\": \"RPA\", \"contractDealDate\": \"2026-02-28T00:00:00\", \"statusDate\": \"2026-02-28T00:00:00\", \"initialExchangeDate\": \"2026-03-01T00:00:00\", \"maturityDate\": \"2026-06-01T00:00:00\", \"notionalPrincipal\": \"{{loan_notional}}\", \"currency\": \"USD\", \"dayCountConvention\": \"30E360\", \"nominalInterestRate\": \"0.0725\", \"cycleOfInterestPayment\": \"P3ML1\", \"cycleAnchorDateOfInterestPayment\": \"2026-06-01T00:00:00\", \"cycleOfRateReset\": \"P3ML1\", \"cycleAnchorDateOfRateReset\": \"2026-03-01T00:00:00\", \"marketObjectCodeOfRateReset\": \"DETERIORATING_SOFR\", \"rateSpread\": \"{{loan_spread}}\", \"rateMultiplier\": \"1.0\"}, {\"contractType\": \"PAM\", \"contractID\": \"LOAN-HEDGED-B\", \"contractRole\": \"RPA\", \"contractDealDate\": \"2026-05-31T00:00:00\", \"statusDate\": \"2026-05-31T00:00:00\", \"initialExchangeDate\": \"2026-06-01T00:00:00\", \"maturityDate\": \"2028-03-01T00:00:00\", \"notionalPrincipal\": \"{{loan_notional}}\", \"currency\": \"USD\", \"dayCountConvention\": \"30E360\", \"nominalInterestRate\": \"0.0725\", \"cycleOfInterestPayment\": \"P3ML1\", \"cycleAnchorDateOfInterestPayment\": \"2026-09-01T00:00:00\", \"cycleOfRateReset\": \"P3ML1\", \"cycleAnchorDateOfRateReset\": \"2026-06-01T00:00:00\", \"marketObjectCodeOfRateReset\": \"DETERIORATING_SOFR\", \"rateSpread\": \"{{loan_spread}}\", \"rateMultiplier\": \"1.0\"}, {\"contractType\": \"SWAPS\", \"contractID\": \"SWAP-LATER-B\", \"contractRole\": \"PFL\", \"currency\": \"USD\", \"contractDealDate\": \"2026-05-31T00:00:00\", \"statusDate\": \"2026-05-31T00:00:00\", \"deliverySettlement\": \"D\", \"contractStructure\": [{\"object\": {\"contractType\": \"PAM\", \"contractID\": \"SWAP-B-FIXED\", \"contractDealDate\": \"2026-05-31T00:00:00\", \"initialExchangeDate\": \"2026-06-01T00:00:00\", \"currency\": \"USD\", \"statusDate\": \"2026-05-31T00:00:00\", \"notionalPrincipal\": \"{{loan_notional}}\", \"dayCountConvention\": \"30E360\", \"nominalInterestRate\": \"{{swap_later_rate}}\", \"maturityDate\": \"2028-03-01T00:00:00\", \"cycleAnchorDateOfInterestPayment\": \"2026-09-01T00:00:00\", \"cycleOfInterestPayment\": \"P3ML1\", \"premiumDiscountAtIED\": \"0\"}, \"referenceType\": \"CNT\", \"referenceRole\": \"FIL\"}, {\"object\": {\"contractType\": \"PAM\", \"contractID\": \"SWAP-B-FLOAT\", \"contractDealDate\": \"2026-05-31T00:00:00\", \"initialExchangeDate\": \"2026-06-01T00:00:00\", \"currency\": \"USD\", \"statusDate\": \"2026-05-31T00:00:00\", \"notionalPrincipal\": \"{{loan_notional}}\", \"dayCountConvention\": \"30E360\", \"nominalInterestRate\": \"0.0635\", \"maturityDate\": \"2028-03-01T00:00:00\", \"cycleAnchorDateOfInterestPayment\": \"2026-09-01T00:00:00\", \"cycleOfInterestPayment\": \"P3ML1\", \"cycleOfRateReset\": \"P3ML1\", \"cycleAnchorDateOfRateReset\": \"2026-06-01T00:00:00\", \"marketObjectCodeOfRateReset\": \"DETERIORATING_SOFR\", \"rateMultiplier\": \"1.0\", \"rateSpread\": \"0.0\", \"premiumDiscountAtIED\": \"0\"}, \"referenceType\": \"CNT\", \"referenceRole\": \"SEL\"}]}], \"riskFactors\": [{\"marketObjectCode\": \"DETERIORATING_SOFR\", \"base\": 1.0, \"data\": [{\"time\": \"2026-03-01T00:00:00\", \"value\": 0.06}, {\"time\": \"2026-06-01T00:00:00\", \"value\": 0.0635}, {\"time\": \"2026-09-01T00:00:00\", \"value\": 0.0665}, {\"time\": \"2026-12-01T00:00:00\", \"value\": 0.0695}, {\"time\": \"2027-03-01T00:00:00\", \"value\": 0.072}, {\"time\": \"2027-06-01T00:00:00\", \"value\": 0.073}, {\"time\": \"2027-09-01T00:00:00\", \"value\": 0.0745}, {\"time\": \"2027-12-01T00:00:00\", \"value\": 0.075}, {\"time\": \"2028-03-01T00:00:00\", \"value\": 0.075}]}]}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('B1-Success', function(){ pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "var unhedgedTotal = 0, hedgedLoanTotal = 0, swapTotal = 0;",
                  "data.forEach(function(c){",
                  "    if(c.contractID === 'LOAN-UNHEDGED-B'){",
                  "        c.events.filter(e => e.type === 'IP').forEach(e => { unhedgedTotal += Math.abs(e.payoff); });",
                  "    } else if(c.contractID === 'LOAN-HEDGED-B'){",
                  "        c.events.filter(e => e.type === 'IP').forEach(e => { hedgedLoanTotal += Math.abs(e.payoff); });",
                  "    } else if(c.contractID === 'SWAP-LATER-B'){",
                  "        c.events.filter(e => e.type === 'IP').forEach(e => { swapTotal += e.payoff; });",
                  "    }",
                  "});",
                  "var total = unhedgedTotal + hedgedLoanTotal + swapTotal;",
                  "console.log('\\n' + '='.repeat(70));",
                  "console.log('SCENARIO B: WAIT & SWAP LATER (June 2026)');",
                  "console.log('='.repeat(70));",
                  "console.log('Phase 1 (3mo UNHEDGED): $' + unhedgedTotal.toFixed(0));",
                  "console.log('Phase 2 Loan Interest:  $' + hedgedLoanTotal.toFixed(0));",
                  "console.log('Phase 2 Swap Net:       $' + swapTotal.toFixed(0));",
                  "console.log('TOTAL COST:             $' + total.toFixed(0));",
                  "console.log('='.repeat(70) + '\\n');",
                  "pm.environment.set('B_total', total);",
                  "pm.environment.set('B_unhedged', unhedgedTotal);",
                  "pm.environment.set('B_hedged_loan', hedgedLoanTotal);",
                  "pm.environment.set('B_swap', swapTotal);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "C. Input Parameters & SOFR Composition",
      "item": [
        {
          "name": "C1-Display-Parameters",
          "request": {
            "method": "GET",
            "header": [],
            "url": "http://localhost:8083/"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "console.log('\\n' + '\u2550'.repeat(80));",
                  "console.log('INPUT PARAMETERS & RISK FACTOR COMPOSITION');",
                  "console.log('\u2550'.repeat(80));",
                  "",
                  "console.log('\\n\ud83d\udccd TRADE CORRIDOR:');",
                  "console.log('  Exporter: ' + pm.collectionVariables.get('exporter_country'));",
                  "console.log('  Importer: ' + pm.collectionVariables.get('importer_country'));",
                  "console.log('  Corridor: ' + pm.collectionVariables.get('corridor_code'));",
                  "console.log('  Commodity: ' + pm.collectionVariables.get('commodity') + ' (GTAP: ' + pm.collectionVariables.get('commodity_code') + ')');",
                  "console.log('  Armington Elasticity (\u03c3): ' + pm.collectionVariables.get('armington_elasticity'));",
                  "",
                  "console.log('\\n\ud83d\udcca TARIFF SCENARIO:');",
                  "console.log('  Current Tariff: ' + (parseFloat(pm.collectionVariables.get('tariff_current'))*100).toFixed(0) + '%');",
                  "console.log('  Peak Tariff: ' + (parseFloat(pm.collectionVariables.get('tariff_peak'))*100).toFixed(0) + '%');",
                  "console.log('  Pass-Through: ' + pm.collectionVariables.get('tariff_pass_through'));",
                  "",
                  "var tariffCurrent = parseFloat(pm.collectionVariables.get('tariff_current'));",
                  "var tariffPeak = parseFloat(pm.collectionVariables.get('tariff_peak'));",
                  "var sigma = parseFloat(pm.collectionVariables.get('armington_elasticity'));",
                  "var passThrough = parseFloat(pm.collectionVariables.get('tariff_pass_through'));",
                  "var tariffImpactInit = tariffCurrent * sigma * passThrough;",
                  "var tariffImpactPeak = tariffPeak * sigma * passThrough;",
                  "",
                  "console.log('\\n\ud83e\uddee CALCULATED TARIFF IMPACT:');",
                  "console.log('  Initial: ' + (tariffCurrent*100).toFixed(0) + '% \u00d7 ' + sigma + ' \u00d7 ' + passThrough + ' = ' + (tariffImpactInit*100).toFixed(2) + '%');",
                  "console.log('  Peak:    ' + (tariffPeak*100).toFixed(0) + '% \u00d7 ' + sigma + ' \u00d7 ' + passThrough + ' = ' + (tariffImpactPeak*100).toFixed(2) + '%');",
                  "",
                  "console.log('\\n\ud83d\udcb0 FINANCING TERMS:');",
                  "console.log('  Loan Amount: $' + parseFloat(pm.collectionVariables.get('loan_notional')).toLocaleString());",
                  "console.log('  Loan Spread: ' + (parseFloat(pm.collectionVariables.get('loan_spread'))*100).toFixed(0) + ' bps');",
                  "console.log('  Swap Now Rate: ' + (parseFloat(pm.collectionVariables.get('swap_now_rate'))*100).toFixed(1) + '%');",
                  "console.log('  Swap Later Rate: ' + (parseFloat(pm.collectionVariables.get('swap_later_rate'))*100).toFixed(1) + '%');",
                  "console.log('  Delay Period: ' + pm.collectionVariables.get('swap_delay_months') + ' months');",
                  "",
                  "var baseSofr = parseFloat(pm.collectionVariables.get('base_sofr_initial'));",
                  "var sovInit = parseFloat(pm.collectionVariables.get('sovereign_stress_initial'));",
                  "var sovPeak = parseFloat(pm.collectionVariables.get('sovereign_stress_peak'));",
                  "var wcInit = parseFloat(pm.collectionVariables.get('wc_stress_initial'));",
                  "var wcPeak = parseFloat(pm.collectionVariables.get('wc_stress_peak'));",
                  "",
                  "console.log('\\n\ud83d\udcc8 DETERIORATING SOFR PATH COMPOSITION:');",
                  "console.log('');",
                  "console.log('  Component        | Initial | Peak   | Driver');",
                  "console.log('  -----------------|---------|--------|------------------------');",
                  "console.log('  Base SOFR        | ' + (baseSofr*100).toFixed(2) + '%  | 4.80%  | Fed policy tightening');",
                  "console.log('  Tariff Impact    | ' + (tariffImpactInit*100).toFixed(2) + '%  | ' + (tariffImpactPeak*100).toFixed(2) + '%  | ' + (tariffCurrent*100).toFixed(0) + '% \u2192 ' + (tariffPeak*100).toFixed(0) + '% tariff');",
                  "console.log('  Country Risk     | ' + sovInit + '%  | ' + sovPeak + '%  | India EM spread widens');",
                  "console.log('  WC Stress        | ' + (wcInit*100).toFixed(2) + '%  | ' + (wcPeak*100).toFixed(2) + '%  | Textile liquidity crunch');",
                  "console.log('  -----------------|---------|--------|------------------------');",
                  "var totalInit = baseSofr + (tariffImpactInit) + (sovInit/100) + wcInit;",
                  "var totalPeak = 0.048 + (tariffImpactPeak) + (sovPeak/100) + wcPeak;",
                  "console.log('  TOTAL            | ' + (totalInit*100).toFixed(2) + '%  | ' + (totalPeak*100).toFixed(2) + '%  | (Sum of components)');",
                  "console.log('');",
                  "console.log('  \ud83d\udccc Swap Now locks at:   ' + (parseFloat(pm.collectionVariables.get('swap_now_rate'))*100).toFixed(1) + '% (priced at ' + (totalInit*100).toFixed(2) + '% environment)');",
                  "console.log('  \ud83d\udccc Swap Later locks at: ' + (parseFloat(pm.collectionVariables.get('swap_later_rate'))*100).toFixed(1) + '% (priced at 6.35% environment)');",
                  "console.log('');",
                  "console.log('\u2550'.repeat(80) + '\\n');"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "D. Cost Comparison",
      "item": [
        {
          "name": "D1-Calculate-Opportunity-Cost",
          "request": {
            "method": "GET",
            "header": [],
            "url": "http://localhost:8083/"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var A_total = parseFloat(pm.environment.get('A_total')) || 0;",
                  "var B_total = parseFloat(pm.environment.get('B_total')) || 0;",
                  "var A_loan = parseFloat(pm.environment.get('A_loan')) || 0;",
                  "var A_swap = parseFloat(pm.environment.get('A_swap')) || 0;",
                  "var B_unhedged = parseFloat(pm.environment.get('B_unhedged')) || 0;",
                  "var B_hedged_loan = parseFloat(pm.environment.get('B_hedged_loan')) || 0;",
                  "var B_swap = parseFloat(pm.environment.get('B_swap')) || 0;",
                  "",
                  "console.log('\\n' + '\u2550'.repeat(80));",
                  "console.log('COST COMPARISON: SWAP NOW vs WAIT');",
                  "console.log('\u2550'.repeat(80));",
                  "",
                  "console.log('\\n\ud83d\udcb5 SCENARIO A: SWAP NOW (March 2026)');",
                  "console.log('  \u251c\u2500 Loan Interest:     $' + A_loan.toFixed(0));",
                  "console.log('  \u251c\u2500 Swap Net Cost:     $' + A_swap.toFixed(0));",
                  "console.log('  \u2514\u2500 TOTAL:             $' + A_total.toFixed(0));",
                  "console.log('     Strategy: Lock at 5.2% immediately, fully hedged for 24 months');",
                  "",
                  "console.log('\\n\ud83d\udcb5 SCENARIO B: WAIT & SWAP LATER (June 2026)');",
                  "console.log('  \u251c\u2500 Phase 1 Unhedged:  $' + B_unhedged.toFixed(0) + ' (3 months at rising rates)');",
                  "console.log('  \u251c\u2500 Phase 2 Loan:      $' + B_hedged_loan.toFixed(0));",
                  "console.log('  \u251c\u2500 Phase 2 Swap:      $' + B_swap.toFixed(0));",
                  "console.log('  \u2514\u2500 TOTAL:             $' + B_total.toFixed(0));",
                  "console.log('     Strategy: Wait 3 months, then lock at 5.8% for 21 months');",
                  "",
                  "if(A_total > 0 && B_total > 0){",
                  "    var diff = B_total - A_total;",
                  "    var perMonth = diff / 24;",
                  "    var bps = (diff / parseFloat(pm.collectionVariables.get('loan_notional'))) * 10000 / 2;",
                  "    console.log('\\n' + '\u2500'.repeat(80));",
                  "    console.log('\ud83d\udcca OPPORTUNITY COST OF WAITING:');",
                  "    console.log('\u2500'.repeat(80));",
                  "    console.log('  Total Extra Cost:     $' + Math.abs(diff).toFixed(0));",
                  "    console.log('  Per Month:            $' + Math.abs(perMonth).toFixed(0));",
                  "    console.log('  Equivalent to:        ~' + Math.abs(bps).toFixed(0) + ' bps higher all-in cost');",
                  "    console.log('');",
                  "    if(diff > 0){",
                  "        console.log('  \u2705 VERDICT: Swapping NOW saves $' + diff.toFixed(0));",
                  "        console.log('  \u2705 Waiting costs you 60bps higher fixed rate (5.8% vs 5.2%)');",
                  "        console.log('  \u2705 PLUS 3 months of unhedged exposure to deteriorating rates');",
                  "    } else {",
                  "        console.log('  \u26a0\ufe0f  Waiting would save money (unexpected - check inputs)');",
                  "    }",
                  "}",
                  "console.log('\\n' + '\u2550'.repeat(80) + '\\n');"
                ]
              }
            }
          ]
        }
