  "item": [
    {
      "name": "A. Swap Now (March 2026)",
      "item": [
        {
          "name": "A1-Swap-Now-Full-Hedge",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "http://localhost:8083/eventsBatch",
            "body": {
              "mode": "raw",
              "raw": "{\"contracts\": [{\"contractType\": \"PAM\", \"contractID\": \"LOAN-FLOAT-A\", \"contractRole\": \"RPA\", \"contractDealDate\": \"2026-02-28T00:00:00\", \"statusDate\": \"2026-02-28T00:00:00\", \"initialExchangeDate\": \"2026-03-01T00:00:00\", \"maturityDate\": \"2028-03-01T00:00:00\", \"notionalPrincipal\": \"{{loan_notional}}\", \"currency\": \"USD\", \"dayCountConvention\": \"30E360\", \"nominalInterestRate\": \"0.0725\", \"cycleOfInterestPayment\": \"P3ML1\", \"cycleAnchorDateOfInterestPayment\": \"2026-06-01T00:00:00\", \"cycleOfRateReset\": \"P3ML1\", \"cycleAnchorDateOfRateReset\": \"2026-03-01T00:00:00\", \"marketObjectCodeOfRateReset\": \"DETERIORATING_SOFR\", \"rateSpread\": \"{{loan_spread}}\", \"rateMultiplier\": \"1.0\"}, {\"contractType\": \"SWAPS\", \"contractID\": \"SWAP-NOW-A\", \"contractRole\": \"PFL\", \"currency\": \"USD\", \"contractDealDate\": \"2026-02-28T00:00:00\", \"statusDate\": \"2026-02-28T00:00:00\", \"deliverySettlement\": \"D\", \"contractStructure\": [{\"object\": {\"contractType\": \"PAM\", \"contractID\": \"SWAP-A-FIXED\", \"contractDealDate\": \"2026-02-28T00:00:00\", \"initialExchangeDate\": \"2026-03-01T00:00:00\", \"currency\": \"USD\", \"statusDate\": \"2026-02-28T00:00:00\", \"notionalPrincipal\": \"{{loan_notional}}\", \"dayCountConvention\": \"30E360\", \"nominalInterestRate\": \"{{swap_now_rate}}\", \"maturityDate\": \"2028-03-01T00:00:00\", \"cycleAnchorDateOfInterestPayment\": \"2026-06-01T00:00:00\", \"cycleOfInterestPayment\": \"P3ML1\", \"premiumDiscountAtIED\": \"0\"}, \"referenceType\": \"CNT\", \"referenceRole\": \"FIL\"}, {\"object\": {\"contractType\": \"PAM\", \"contractID\": \"SWAP-A-FLOAT\", \"contractDealDate\": \"2026-02-28T00:00:00\", \"initialExchangeDate\": \"2026-03-01T00:00:00\", \"currency\": \"USD\", \"statusDate\": \"2026-02-28T00:00:00\", \"notionalPrincipal\": \"{{loan_notional}}\", \"dayCountConvention\": \"30E360\", \"nominalInterestRate\": \"0.0600\", \"maturityDate\": \"2028-03-01T00:00:00\", \"cycleAnchorDateOfInterestPayment\": \"2026-06-01T00:00:00\", \"cycleOfInterestPayment\": \"P3ML1\", \"cycleOfRateReset\": \"P3ML1\", \"cycleAnchorDateOfRateReset\": \"2026-03-01T00:00:00\", \"marketObjectCodeOfRateReset\": \"DETERIORATING_SOFR\", \"rateMultiplier\": \"1.0\", \"rateSpread\": \"0.0\", \"premiumDiscountAtIED\": \"0\"}, \"referenceType\": \"CNT\", \"referenceRole\": \"SEL\"}]}], \"riskFactors\": [{\"marketObjectCode\": \"DETERIORATING_SOFR\", \"base\": 1.0, \"data\": [{\"time\": \"2026-03-01T00:00:00\", \"value\": 0.06}, {\"time\": \"2026-06-01T00:00:00\", \"value\": 0.0635}, {\"time\": \"2026-09-01T00:00:00\", \"value\": 0.0665}, {\"time\": \"2026-12-01T00:00:00\", \"value\": 0.0695}, {\"time\": \"2027-03-01T00:00:00\", \"value\": 0.072}, {\"time\": \"2027-06-01T00:00:00\", \"value\": 0.073}, {\"time\": \"2027-09-01T00:00:00\", \"value\": 0.0745}, {\"time\": \"2027-12-01T00:00:00\", \"value\": 0.075}, {\"time\": \"2028-03-01T00:00:00\", \"value\": 0.075}]}]}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('A1-Success', function(){ pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "var loanTotal = 0, swapTotal = 0;",
                  "data.forEach(function(c){",
                  "    if(c.contractID === 'LOAN-FLOAT-A'){",
                  "        c.events.filter(e => e.type === 'IP').forEach(e => { loanTotal += Math.abs(e.payoff); });",
                  "    } else if(c.contractID === 'SWAP-NOW-A'){",
                  "        c.events.filter(e => e.type === 'IP').forEach(e => { swapTotal += e.payoff; });",
                  "    }",
                  "});",
                  "var total = loanTotal + swapTotal;",
                  "console.log('\\n' + '='.repeat(70));",
                  "console.log('SCENARIO A: SWAP NOW (March 2026)');",
                  "console.log('='.repeat(70));",
                  "console.log('Loan Interest Cost: $' + loanTotal.toFixed(0));",
                  "console.log('Swap Net Cost/Gain: $' + swapTotal.toFixed(0));",
                  "console.log('TOTAL HEDGED COST: $' + total.toFixed(0));",
                  "console.log('='.repeat(70) + '\\n');",
                  "pm.environment.set('A_total', total);",
                  "pm.environment.set('A_loan', loanTotal);",
                  "pm.environment.set('A_swap', swapTotal);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "B. Wait & Swap Later (June 2026)",
      "item": [
        {
