          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Simulation success', function(){",
              "    pm.response.to.have.status(200);",
              "    var data = pm.response.json();",
              "    console.log('='.repeat(64));",
              "    console.log('SWAPS IN-Textiles (PFL - CORRECT HEDGE DIRECTION)');",
              "    console.log('='.repeat(64));",
              "    var r = data[0];",
              "    if(r.status !== 'Success'){ console.log('FAILED: ' + (r.statusMessage||'unknown')); return; }",
              "    var events = r.events;",
              "    console.log('Status: ' + r.status + ' | Events: ' + events.length);",
              "    var counts = {};",
              "    events.forEach(function(e){ counts[e.type] = (counts[e.type]||0)+1; });",
              "    Object.keys(counts).sort().forEach(function(k){ console.log('  ' + k + ': ' + counts[k]); });",
              "    var totalIP = 0;",
              "    console.log('');",
              "    console.log('INTEREST PAYMENTS (per quarter):');",
              "    var ipEvents = events.filter(function(e){return e.type==='IP';});",
              "    for(var i=0; i<ipEvents.length; i+=2){",
              "        var e1 = ipEvents[i]; var e2 = ipEvents[i+1];",
              "        if(!e2) break;",
              "        var net = e1.payoff + e2.payoff;",
              "        totalIP += e1.payoff + e2.payoff;",
              "        var dt = e1.time.substring(0,10);",
              "        var fixedP = e1.nominalValue > 0 ? e1 : e2;",
              "        var floatP = e1.nominalValue < 0 ? e1 : e2;",
              "        console.log('  ' + dt + '  fixed=' + fixedP.payoff.toFixed(0) + '  float=' + floatP.payoff.toFixed(0) + '  NET=' + net.toFixed(0) + (net>0?' (swap PAYS exporter)':net<0?' (swap COSTS exporter)':' (break-even)'));",
              "    }",
              "    console.log('');",
              "    console.log('TOTAL NET IP over 3 years: $' + totalIP.toFixed(2));",
              "    console.log(totalIP < 0 ? 'HEDGE COST: Exporter paid net $'+Math.abs(totalIP).toFixed(0)+' for rate certainty (insurance premium)' : 'HEDGE GAIN: Exporter earned net $'+totalIP.toFixed(0)+' (tariff storm was severe enough that protection paid for itself)');",
              "    console.log('='.repeat(64));",
              "});"
            ]
          }
