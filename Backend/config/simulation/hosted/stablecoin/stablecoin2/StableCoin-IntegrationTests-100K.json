            "body": {
              "mode": "raw",
              "raw": "{\"riskFactorID\":\"TEST_RESERVES_01\",\"marketObjectCode\":\"SC_TOTAL_RESERVES\",\"base\":1.0,\"data\":[{\"time\":\"2026-03-01T00:00:00\",\"value\":104000},{\"time\":\"2026-03-15T00:00:00\",\"value\":97500},{\"time\":\"2026-03-30T00:00:00\",\"value\":105000}]}"
            }
