          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('A1-Success', function(){ pm.response.to.have.status(200); });",
                  "var data = pm.response.json();",
                  "var loanTotal = 0;",
                  "data.forEach(function(c){",
                  "    if(c.contractID === 'LOAN-FLOAT-ONLY'){",
                  "        c.events.filter(e => e.type === 'IP').forEach(e => { loanTotal += Math.abs(e.payoff); });",
                  "    }",
                  "});",
                  "console.log('\\n' + '='.repeat(70));",
                  "console.log('SCENARIO A: NO HEDGE (Baseline - Fully Exposed)');",
                  "console.log('='.repeat(70));",
                  "console.log('Loan Interest Cost: $' + loanTotal.toFixed(0));",
                  "console.log('NO SWAP - Full exposure to rising SOFR');",
                  "console.log('TOTAL COST: $' + loanTotal.toFixed(0));",
                  "console.log('='.repeat(70) + '\\n');",
                  "pm.environment.set('A_total', loanTotal);",
