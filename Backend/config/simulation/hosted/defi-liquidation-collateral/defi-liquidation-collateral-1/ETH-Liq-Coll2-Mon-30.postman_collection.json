    {
      "name": "6. Run Simulation",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Simulation succeeded', function(){",
              "    pm.response.to.have.status(200);",
              "    var data = pm.response.json();",
              "    pm.expect(data[0].status).to.eql('Success');",
              "    var events = data[0].events;",
              "    console.log('PASS: ' + events.length + ' events generated');",
              "    console.log('');",
              "    var counts = {};",
              "    events.forEach(function(e){counts[e.type]=(counts[e.type]||0)+1;});",
              "    Object.keys(counts).forEach(function(k){console.log('  '+k+': '+counts[k]);});",
              "    console.log('');",
              "    console.log('=== RATE STORY ===');",
              "    var rrs = events.filter(function(e){return e.type==='RR';});",
              "    var minRate=1,maxRate=0,minDate='',maxDate='';",
              "    rrs.forEach(function(r){",
              "        if(r.nominalRate<minRate){minRate=r.nominalRate;minDate=r.time;}",
              "        if(r.nominalRate>maxRate){maxRate=r.nominalRate;maxDate=r.time;}",
              "    });",
              "    console.log('  Lowest rate:  '+(minRate*100).toFixed(2)+'% on '+minDate);",
              "    console.log('  Highest rate: '+(maxRate*100).toFixed(2)+'% on '+maxDate);",
              "    console.log('  Final rate:   '+(rrs[rrs.length-1].nominalRate*100).toFixed(2)+'%');",
              "    console.log('');",
              "    console.log('=== PREPAYMENT CHECKS ===');",
              "    var pps = events.filter(function(e){return e.type==='PP';});",
              "    pps.forEach(function(pp){",
              "        var action = pp.payoff>0 ? 'PREPAID $'+pp.payoff.toFixed(2) : 'no prepay (spread negative)';",
              "        console.log('  '+pp.time+' -> '+action+' | notional=$'+pp.nominalValue.toFixed(2));",
              "    });",
              "    console.log('');",
              "    var ip = events.filter(function(e){return e.type==='IP';})[0];",
              "    var md = events.filter(function(e){return e.type==='MD';})[0];",
              "    console.log('=== FINAL SETTLEMENT ===');",
              "    console.log('  Interest paid:      $'+ip.payoff.toFixed(2));",
              "    console.log('  Principal returned:  $'+md.payoff.toFixed(2));",
              "    console.log('  Total prepaid:       $'+(5000-md.payoff).toFixed(2));",
              "});"
            ]
          }
        }
