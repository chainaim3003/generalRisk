    {
      "name": "7. Run Portfolio Simulation (100Y Perpetual, 1Y Sim)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Step 7: ETH Portfolio 100Y/1Y simulation', function(){",
              "    pm.response.to.have.status(200);",
              "    var data = pm.response.json();",
              "    console.log('════════════════════════════════════════════════════════════');",
              "    console.log('ETH PORTFOLIO 100-YEAR PERPETUAL MODEL (1-YEAR SIMULATION)');",
              "    console.log('  Total ETH: 7.0 (3.0 collateral + 4.0 buffer)');",
              "    console.log('  Maturity: 2126-02-18 (100 years)');",
              "    console.log('  Simulation: 2026-02-18 to 2027-02-18 (365 days)');",
              "    console.log('════════════════════════════════════════════════════════════');",
              "    console.log('Total contracts simulated: ' + data.length);",
              "    console.log('');",
              "    ",
              "    var collateralCOM = data.find(function(c){return (c.contractId||c.contractID||'').includes('Collateral');});",
              "    var bufferCOM = data.find(function(c){return (c.contractId||c.contractID||'').includes('Buffer');});",
              "    var pamLoan = data.find(function(c){return (c.contractId||c.contractID||'').includes('DeFi-ETH');});",
              "    ",
              "    console.log('══ PORTFOLIO BREAKDOWN ══');",
              "    if(collateralCOM){",
              "        console.log('1. Collateral ETH (COM): 3.0 ETH - ' + (collateralCOM.events||[]).length + ' events');",
              "    }",
              "    if(bufferCOM){",
              "        console.log('2. Buffer ETH (COM): 4.0 ETH - ' + (bufferCOM.events||[]).length + ' events');",
              "    }",
              "    if(pamLoan){",
              "        var events = pamLoan.events || [];",
              "        console.log('3. Loan (PAM): $5,000 - ' + events.length + ' events');",
              "        var rrCount = events.filter(function(e){return e.type==='RR';}).length;",
              "        var ipCount = events.filter(function(e){return e.type==='IP';}).length;",
              "        var ppCount = events.filter(function(e){return e.type==='PP';}).length;",
              "        var mdCount = events.filter(function(e){return e.type==='MD';}).length;",
              "        console.log('   → RR (Rate Reset): ' + rrCount);",
              "        console.log('   → IP (Interest): ' + ipCount);",
              "        console.log('   → PP (Prepayment): ' + ppCount);",
              "        console.log('   → MD (Maturity): ' + mdCount + ' (should be 0 for perpetual)');",
              "    }",
              "    console.log('');",
              "    ",
              "    console.log('══ AGE DIMENSION VERIFICATION ══');",
              "    console.log('100-year MD ensures age stays within surface range:');",
              "    console.log('  Day 30:  age = 30/36500  = 0.082% ✅ (vs 100% with 30-day MD)');",
              "    console.log('  Day 90:  age = 90/36500  = 0.247% ✅');",
              "    console.log('  Day 180: age = 180/36500 = 0.493% ✅');",
              "    console.log('  Day 365: age = 365/36500 = 1.000% ✅');",
              "    console.log('  Surface range: [0%, 2.5%, 5%, 8.3%] - Perfect fit!');",
              "    console.log('');",
              "    ",
              "    if(pamLoan && pamLoan.events){",
              "        var events = pamLoan.events;",
              "        var pps = events.filter(function(e){return e.type==='PP' && e.payoff > 0;});",
              "        if(pps.length > 0){",
              "            console.log('══ DELEVERAGING EVENTS (First 30 days) ══');",
              "            pps.slice(0,5).forEach(function(pp){",
              "                console.log('  ' + pp.time + ': $' + pp.payoff.toFixed(2) + ' → notional=$' + pp.nominalValue.toFixed(2));",
              "            });",
              "            if(pps.length > 5) console.log('  ... and ' + (pps.length-5) + ' more events');",
              "        }",
              "        console.log('');",
              "        ",
              "        var lastEvent = events[events.length - 1];",
              "        if(lastEvent){",
              "            console.log('══ FINAL STATE (End of Year 1) ══');",
              "            console.log('  Last event: ' + lastEvent.type + ' at ' + lastEvent.time);",
              "            console.log('  Final notional: $' + (lastEvent.nominalValue || 0).toFixed(2));",
              "            console.log('  Contract status: OPEN (no MD event - perpetual)');",
              "            console.log('');",
              "            console.log('  ⚠️  NOTE: Rates/prices constant after day 30 (extend indices for full year)');",
              "        }",
              "    }",
              "    console.log('════════════════════════════════════════════════════════════');",
              "});"
            ]
          }
        }
      ],
