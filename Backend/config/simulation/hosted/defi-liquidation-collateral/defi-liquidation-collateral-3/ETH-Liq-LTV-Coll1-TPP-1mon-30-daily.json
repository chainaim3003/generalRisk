    {
      "name": "7. Run Competing-Risk Simulation",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Step 7: Combined behavioral simulation', function(){",
              "    pm.response.to.have.status(200);",
              "    var data = pm.response.json();",
              "    pm.expect(data[0].status).to.eql('Success');",
              "    var events = data[0].events;",
              "    console.log('════════════════════════════════════════════════════════════');",
              "    console.log('COMPETING RISKS SIMULATION RESULTS');",
              "    console.log('  Deng, Quigley & Van Order (2000) framework applied to DeFi');",
              "    console.log('  Risk 1: TwoDimensionalPrepayment (voluntary, rate-driven)');",
              "    console.log('  Risk 2: CollateralLTV (forced, price-driven)');",
              "    console.log('════════════════════════════════════════════════════════════');",
              "    console.log('Total events: ' + events.length);",
              "    console.log('');",
              "",
              "    // Count event types",
              "    var counts = {};",
              "    events.forEach(function(e){counts[e.type]=(counts[e.type]||0)+1;});",
              "    Object.keys(counts).forEach(function(k){console.log('  '+k+': '+counts[k]);});",
              "    console.log('');",
              "",
              "    // Show ALL PP events (from both behavioral models)",
              "    var pps = events.filter(function(e){return e.type==='PP';});",
              "    console.log('══ BEHAVIORAL EVENTS (PP) ══');",
              "    console.log('  Both prepayment (voluntary) and LTV (forced) generate PP events.');",
              "    console.log('  Key insight: voluntary prepayment REDUCES debt that LTV model sees.');",
              "    console.log('');",
              "    pps.forEach(function(pp){",
