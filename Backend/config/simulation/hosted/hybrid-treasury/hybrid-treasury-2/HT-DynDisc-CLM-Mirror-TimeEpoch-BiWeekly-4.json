          "_comment": [
            "scenarioSimulation — UPDATED in v9",
            "ADDED:   CASH-RESERVE-SEED (CSH) — notionalPrincipal=$2,750,000",
            "         Represents opening consolidated reserve = $1M seed + $1.75M T-bills",
            "         CSH produces zero events (correct ACTUS behaviour) — anchors the reserve",
            "FIX:     CASH-PAM-3M.treasuryModels now contains BOTH [ad_btc01_mirror, lb_tr01]",
            "         lb_tr01 was floating in v8 — now formally attached so it monitors CASH-PAM",
            "UNCHANGED: BTC-CLM-Lending-40, all 4 T-Bill PAMs",
            "",
            "Contract roles in the consolidated reserve:",
            "  CASH-RESERVE-SEED  : CSH anchor — opens $2.75M reserve at Mar-01, no cashflow events",
            "  BTC-CLM-Lending-40 : Digital asset — $2M lent at 3%, BTC sales reduce principal",
            "  CASH-PAM-3M        : Cash reserve vehicle — holds BTC sale proceeds + $1M seed",
            "                       lb_tr01 monitors at each epoch vs T-bill ladder",
            "  TBILL-*            : Liquidity ladder — maturities feed free cash; lb_tr01 reads schedule",
            "",
            "Expected IED payoffs (Mar-01):",
            "  CSH:       no IED event (zero cashflow)",
            "  CLM IED:   -$2,000,000",
            "  PAM IED:   -(3,000,000 + (-2,000,000)) = -$1,000,000",
            "  TBILL-Jun: -$250,000  (purchased Mar-01)",
            "  TBILL-Jul: -$500,000  (purchased Mar-01)"
          ],
          "response": [],
          "event": [{
            "listen": "test",
            "script": {
              "type": "text/javascript",
              "exec": [
                "pm.test('scenarioSimulation ht_v9 status 200', function () { pm.response.to.have.status(200); });",
                "",
                "var raw = pm.response.text();",
                "try {",
                "  var data = JSON.parse(raw);",
                "",
                "  // ─────────────────────────────────────────────────────────────",
                "  // 1. BUILD per-contract event lookup: contractID → { date → payoff }",
                "  // ─────────────────────────────────────────────────────────────",
                "  var contractMap = {};",
                "  if (Array.isArray(data)) {",
                "    data.forEach(function(cr) {",
                "      var cid = cr.contractId || cr.contractID || 'unknown';",
                "      contractMap[cid] = {};",
                "      var evts = cr.events || cr.cashFlows || [];",
                "      evts.forEach(function(ev) {",
                "        var d = (ev.time || ev.date || '').slice(0, 10);",
                "        var p = ev.payoff !== undefined ? ev.payoff : (ev.value || 0);",
                "        contractMap[cid][d] = (contractMap[cid][d] || 0) + p;",
                "      });",
                "    });",
                "  }",
                "",
                "  // ─────────────────────────────────────────────────────────────",
                "  // 2. PRINT individual contract event tables",
                "  // ─────────────────────────────────────────────────────────────",
                "  console.log('');",
                "  console.log('══════════════════════════════════════════════════════════════════');",
                "  console.log('  HT v9 — Per-Contract Event Trace');",
                "  console.log('══════════════════════════════════════════════════════════════════');",
                "  if (Array.isArray(data)) {",
                "    data.forEach(function(cr) {",
                "      var cid = cr.contractId || cr.contractID || 'unknown';",
                "      var evts = cr.events || cr.cashFlows || [];",
                "      console.log('');",
                "      console.log('  ┌─ ' + cid + '  (' + evts.length + ' events)');",
                "      evts.forEach(function(ev) {",
                "        var t  = (ev.time || ev.date || '').slice(0, 10);",
                "        var et = ev.eventType || ev.type || '';",
                "        var pv = ev.payoff  !== undefined ? ev.payoff  : (ev.value  || 0);",
                "        var nv = ev.nominalValue !== undefined ? ev.nominalValue : '';",
                "        var tag = '';",
                "        if (et === 'PP' && cid === 'BTC-CLM-Lending-40') tag = ' ← BTC sale (drift breach)';",
                "        if (et === 'PP' && cid === 'CASH-PAM-3M')         tag = ' ← mirror: BTC proceeds locked into reserve';",
                "        if (et === 'MD' && cid === 'CASH-PAM-3M')         tag = ' ← FULL reserve returned';",
                "        if (et === 'MD' && cid.indexOf('TBILL') === 0)    tag = ' ← free cash: T-bill matured';",
                "        if (et === 'IPCI')                                 tag = ' (interest capitalised into CLM)';",
                "        console.log('  │  [' + et + '] ' + t + '  payoff=' + pv.toFixed(2) + '  nomVal=' + (nv !== '' ? Number(nv).toFixed(2) : 'n/a') + tag);",
                "      });",
                "    });",
                "  }",
                "",
                "  // ─────────────────────────────────────────────────────────────",
                "  // 3. CONSOLIDATED CASH RESERVE — epoch-by-epoch table",
                "  // ─────────────────────────────────────────────────────────────",
                "  console.log('');",
                "  console.log('══════════════════════════════════════════════════════════════════');",
                "  console.log('  HT v9 — Consolidated Cash Reserve at Each Time Epoch');",
                "  console.log('  Legend: (+) cash in  |  (−) cash out  |  [locked] = in CASH-PAM until MD');",
                "  console.log('══════════════════════════════════════════════════════════════════');",
                "",
                "  // Epoch definitions with expected cash events",
                "  var epochs = [",
                "    { date: '2026-03-01', label: 'Mar-01 IED' },",
                "    { date: '2026-03-15', label: 'Mar-15' },",
                "    { date: '2026-03-31', label: 'Mar-31 TBILL-Mar MD' },",
                "    { date: '2026-04-15', label: 'Apr-15' },",
                "    { date: '2026-04-30', label: 'Apr-30' },",
                "    { date: '2026-05-15', label: 'May-15 BTC PP#1' },",
                "    { date: '2026-05-31', label: 'May-31 BTC PP#2 + TBILL-May MD' },",
                "    { date: '2026-06-15', label: 'Jun-15 BTC PP#3' },",
                "    { date: '2026-06-30', label: 'Jun-30 BTC PP#4 + TBILL-Jun MD' },",
                "    { date: '2026-07-15', label: 'Jul-15' },",
                "    { date: '2026-07-31', label: 'Jul-31 TBILL-Jul MD' },",
                "    { date: '2026-08-15', label: 'Aug-15' },",
                "    { date: '2026-08-31', label: 'Aug-31 CLM MD + CASH-PAM MD' }",
                "  ];",
                "",
                "  var freeCash     = 0;   // cash received and freely available (T-bill proceeds)",
                "  var cashPamNP    = 3000000; // CASH-PAM notional — starts at $3M",
                "  var clmPrincipal = 2000000; // CLM notional — starts at $2M",
                "  var tbillsOutstanding = 1750000; // T-bills outstanding at Mar-01",
                "",
                "  console.log('  ' + pad('Epoch', 36) + pad('FreeCash', 14) + pad('CASH-PAM NP', 14) + pad('T-Bills', 12) + pad('CLM Prin', 12) + 'Consolidated');",
                "  console.log('  ' + pad('-----', 36) + pad('--------', 14) + pad('-----------', 14) + pad('-------', 12) + pad('--------', 12) + '------------');",
                "",
                "  epochs.forEach(function(ep) {",
                "    var d = ep.date;",
                "",
                "    // Accumulate free cash from T-bill MDs at this epoch",
                "    var tbillMD = (contractMap['TBILL-3mo-500K-Mar'] || {})[d] || 0;",
                "    tbillMD    += (contractMap['TBILL-5mo-500K-May'] || {})[d] || 0;",
                "    tbillMD    += (contractMap['TBILL-4mo-250K-Jun'] || {})[d] || 0;",
                "    tbillMD    += (contractMap['TBILL-5mo-500K-Jul'] || {})[d] || 0;",
                "    freeCash   += tbillMD;",
                "    tbillsOutstanding -= tbillMD;",
                "    if (tbillsOutstanding < 0) tbillsOutstanding = 0;",
                "",
                "    // Update CASH-PAM NP from mirror PP events",
                "    var pamPP = (contractMap['CASH-PAM-3M'] || {})[d] || 0;",
                "    if (pamPP < 0) { cashPamNP -= pamPP; } // mirror PP is negative payoff = NP grows",
                "",
                "    // Update CLM principal from PP events (CLM PP is positive payoff = principal reduces)",
                "    var clmPP = (contractMap['BTC-CLM-Lending-40'] || {})[d] || 0;",
                "    if (clmPP > 0 && d !== '2026-08-31') { clmPrincipal -= clmPP; }",
                "",
                "    // On CLM+PAM maturity (Aug-31): receive both back into freeCash",
                "    var clmMD = (contractMap['BTC-CLM-Lending-40'] || {})[d] || 0;",
                "    var pamMD = (contractMap['CASH-PAM-3M'] || {})[d] || 0;",
                "    if (d === '2026-08-31') {",
                "      freeCash += clmMD;   // CLM principal + final interest",
                "      freeCash += pamMD;   // full CASH-PAM reserve returned",
                "      clmPrincipal = 0;",
                "      cashPamNP    = 0;",
                "    }",
                "",
                "    var consolidated = freeCash + cashPamNP + tbillsOutstanding + (d === '2026-08-31' ? 0 : clmPrincipal);",
                "    if (d === '2026-08-31') consolidated = freeCash; // all positions closed",
                "",
                "    console.log('  ' + pad(ep.label, 36) + pad(fmtUSD(freeCash), 14) + pad(fmtUSD(cashPamNP), 14) + pad(fmtUSD(tbillsOutstanding), 12) + pad(fmtUSD(clmPrincipal), 12) + fmtUSD(consolidated));",
                "  });",
                "",
                "  console.log('');",
                "  console.log('  Note: CASH-PAM NP includes BTC proceeds locked until Aug-31 MD.');",
                "  console.log('  T-Bills column = outstanding par value (reduces as each matures).');",
                "  console.log('  FreeCash = T-bill MD proceeds + CLM+PAM MD receipts at Aug-31.');",
                "  console.log('  Jun-30: lb_tr01 detects: TBILL $250K − outflow $450K = −$200K ⚠ breach');",
                "  console.log('          BTC PP#4 $99,304 in CASH-PAM provides backing for this gap.');",
                "  console.log('══════════════════════════════════════════════════════════════════');",
                "",
                "} catch(e) {",
                "  console.log('Could not parse response as JSON: ' + e.message);",
                "  console.log(raw.slice(0, 2000));",
                "}",
                "",
                "// Helpers",
                "function pad(s, n) { s = String(s); while (s.length < n) s = s + ' '; return s; }",
                "function fmtUSD(v) {",
                "  if (v === 0) return '$0';",
                "  return '$' + Math.round(v).toLocaleString('en-US');",
                "}"
              ]
            }
          }]
        }
      ],
      "description": "Single simulation with 7 contracts: CSH anchor + CLM + CASH-PAM(lb attached) + 4 T-Bills. Test script prints per-contract event trace then consolidated epoch reserve table."
    }
