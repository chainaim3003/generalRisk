    {
      "name": "04 Derive & Register Risk Factors from Contracts",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var tbills = [",
              "  { id: 'TBILL-3mo-400K', maturityDate: '2026-06-01T00:00:00', face: 400000 },",
              "  { id: 'TBILL-4mo-350K', maturityDate: '2026-07-01T00:00:00', face: 350000 },",
              "  { id: 'TBILL-5mo-250K', maturityDate: '2026-08-01T00:00:00', face: 250000 }",
              "];",
              "var opsBase = [",
              "  { time: '2026-03-01T00:00:00', ops: 30000 },",
              "  { time: '2026-03-31T00:00:00', ops: 30000 },",
              "  { time: '2026-04-30T00:00:00', ops: 36000 },",
              "  { time: '2026-05-31T00:00:00', ops: 45000 },",
              "  { time: '2026-06-15T00:00:00', ops: 90000 },",
              "  { time: '2026-06-30T00:00:00', ops: 135000 },",
              "  { time: '2026-07-15T00:00:00', ops: 60000 },",
              "  { time: '2026-07-31T00:00:00', ops: 45000 },",
              "  { time: '2026-08-31T00:00:00', ops: 30000 }",
              "];",
              "var tbillMatData = [{ time: '2026-03-01T00:00:00', value: 0 }];",
              "var scfSchedule = []; var scfMonTimes = [];",
              "tbills.forEach(function(t) {",
              "  tbillMatData.push({ time: t.maturityDate, value: t.face });",
              "  scfSchedule.push({ time: t.maturityDate, amountUSD: t.face });",
              "  scfMonTimes.push(t.maturityDate);",
              "});",
              "var base = 'http://34.203.247.32:8082';",
              "pm.sendRequest({ url: base+'/addReferenceIndex', method:'POST', header:{'Content-Type':'application/json'}, body:{mode:'raw',raw:JSON.stringify({riskFactorID:'OUTFLOWS_01',marketObjectCode:'PROJECTED_OUTFLOWS',base:1.0,data:opsBase.map(function(o){return {time:o.time,value:o.ops};})})} }, function(e1,r1) {",
              "  pm.environment.set('derive_outflows_status', e1?'ERR':String(r1.code));",
              "  pm.sendRequest({ url: base+'/addReferenceIndex', method:'POST', header:{'Content-Type':'application/json'}, body:{mode:'raw',raw:JSON.stringify({riskFactorID:'TBILL_MAT_01',marketObjectCode:'TBILL_MATURITY_SCHEDULE',base:1.0,data:tbillMatData})} }, function(e2,r2) {",
              "    pm.environment.set('derive_tbillmat_status', e2?'ERR':String(r2.code));",
              "    pm.sendRequest({ url: base+'/addScheduledCashFlowModel', method:'POST', header:{'Content-Type':'application/json'}, body:{mode:'raw',raw:JSON.stringify({riskFactorId:'scf_tbill_flows_01',cashFlowSchedule:scfSchedule,monitoringEventTimes:scfMonTimes})} }, function(e3,r3) {",
              "      pm.environment.set('derive_scf_status', e3?'ERR':String(r3.code));",
              "      console.log('[Derive] OUTFLOWS='+pm.environment.get('derive_outflows_status')+' TBILL_MAT='+pm.environment.get('derive_tbillmat_status')+' SCF='+pm.environment.get('derive_scf_status'));",
              "    });",
              "  });",
              "});"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('04 server reachable', function() { pm.expect(pm.response.code).to.be.oneOf([200,404,405]); });",
              "pm.test('04 OUTFLOWS_01 posted', function() { pm.expect(pm.environment.get('derive_outflows_status')).to.equal('200'); });",
              "pm.test('04 TBILL_MAT_01 posted', function() { pm.expect(pm.environment.get('derive_tbillmat_status')).to.equal('200'); });",
              "pm.test('04 scf_tbill_flows_01 posted', function() { pm.expect(pm.environment.get('derive_scf_status')).to.equal('200'); });"
            ]
          }
        }
      ],
