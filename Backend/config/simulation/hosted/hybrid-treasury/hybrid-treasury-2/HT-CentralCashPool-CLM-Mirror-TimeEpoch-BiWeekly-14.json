      "name": "09 scenarioSimulation — ht_v17_4m_1clm_buyhold_scn01",
      "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
        "// ── EXPECTED RESULTS ───────────────────────────────────────────────────",
        "// Mar-15, Mar-31:  NO PP signals (alloc 26.8%, 28.6% — in band)",
        "// Apr-15:  CLM SELL PP ≈ -$225,000 · CASH-PAM mirror +$225,000",
        "// Apr-30, May-15:  NO PP signals (alloc 26.8%, 28.7% — in band)",
        "// May-31:  CLM SELL PP ≈ -$217,500 · CASH-PAM mirror +$217,500",
        "// Jun-01:  TBILL-3mo MD +$400,000",
        "// Jun-30:  NO breach (13.75 BTC × $90K / $4.24M = 29.2%)",
        "// Jul-01:  TBILL-4mo MD +$350,000",
