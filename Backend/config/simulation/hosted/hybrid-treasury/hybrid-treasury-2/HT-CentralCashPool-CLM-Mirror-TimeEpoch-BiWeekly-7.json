    {
      "name": "12 scf_tbill_flows_01 — addScheduledCashFlowModel",
      "event": [{"listen": "test","script": {"type": "text/javascript","exec": [
        "// NEW in v11: ScheduledCashFlowModel routes T-Bill IED/MD into CASH-PAM as PP signals.",
        "// Cash flow schedule (all amounts in USD, signed):",
        "//   2026-03-01  -$750,000  T-Bill IED outflows (TBILL-4mo-250K + TBILL-5mo-500K purchased)",
        "//   2026-03-31  +$500,000  TBILL-3mo-500K-Mar matures",
        "//   2026-05-31  +$500,000  TBILL-5mo-500K-May matures",
        "//   2026-06-30  +$250,000  TBILL-4mo-250K-Jun matures",
        "//   2026-07-31  +$500,000  TBILL-5mo-500K-Jul matures",
        "// Net T-Bill flows into CASH-PAM: -$750K + $1.75M = +$1,000,000",
        "// Signal = amountUSD / abs(CASH-PAM NP) at callout time",
        "// POF_PP_rf2 payoff = roleSign(1) * signal * NP = amountUSD (correct dollar amount)",
        "pm.test('12 scf_tbill_flows_01 registered OK', function() { pm.response.to.have.status(200); pm.expect(pm.response.text()).to.include('added'); });",
        "console.log('12 scf_tbill_flows_01 (ScheduledCashFlowModel — NEW in v11) : ' + pm.response.code + ' ' + pm.response.text().trim());",
        "console.log('   T-Bill IED outflows and MD inflows now tracked in CASH-PAM NP.');"
      ]}}],
      "request": {
        "method": "POST",
