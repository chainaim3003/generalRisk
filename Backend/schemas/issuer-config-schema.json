{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://actus.org/schemas/issuer-config.json",
  "title": "Issuer Simulation Configuration",
  "type": "object",
  "required": ["config_metadata", "jurisdiction", "simulation_timeframe"],
  
  "properties": {
    "config_metadata": {
      "type": "object",
      "required": ["config_id", "collection_file"],
      "properties": {
        "config_id": {"type": "string", "minLength": 1},
        "description": {"type": "string"},
        "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
        "is_default": {"type": "boolean"},
        "collection_file": {"type": "string", "pattern": "\\.json$"}
      }
    },
    
    "jurisdiction": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": {"enum": ["inline", "file"]},
        "file": {"type": "string"},
        "inline": {
          "type": "object",
          "required": [
            "backing_threshold", "liquidity_threshold", "wam_max_days",
            "hqla_min_score", "attestation_max_days", "max_single_asset_share",
            "hhi_warning_threshold", "bank_stress_threshold",
            "base_quality", "quality_floor", "sovereign_max_degradation"
          ],
          "properties": {
            "jurisdiction_code": {"type": "string"},
            "jurisdiction_name": {"type": "string"},
            "backing_threshold": {"type": "number", "minimum": 0},
            "liquidity_threshold": {"type": "number", "minimum": 0, "maximum": 1},
            "wam_max_days": {"type": "number", "minimum": 1},
            "hqla_min_score": {"type": "number", "minimum": 0, "maximum": 100},
            "attestation_max_days": {"type": "number", "minimum": 1},
            "max_single_asset_share": {"type": "number", "minimum": 0, "maximum": 1},
            "hhi_warning_threshold": {"type": "number", "minimum": 0, "maximum": 1},
            "bank_stress_threshold": {"type": "number", "minimum": 0, "maximum": 1},
            "base_quality": {"type": "number", "minimum": 0, "maximum": 100},
            "quality_floor": {"type": "number", "minimum": 0, "maximum": 100},
            "sovereign_max_degradation": {"type": "number", "minimum": 0, "maximum": 1}
          }
        }
      }
    },
    
    "market_scenario": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": {"enum": ["inline", "file"]},
        "file": {"type": "string"}
      }
    },
    
    "compliance_scenario": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": {"enum": ["inline", "file"]},
        "file": {"type": "string"}
      }
    },
    
    "simulation_timeframe": {
      "type": "object",
      "required": ["frequency"],
      "properties": {
        "status_date": {"type": "string", "format": "date-time"},
        "start_date": {"type": "string", "format": "date-time"},
        "end_date": {"type": "string", "format": "date-time"},
        "duration_days": {"type": "integer", "minimum": 1, "maximum": 365},
        "frequency": {"enum": ["daily", "weekly", "monthly"]}
      }
    }
  }
}
