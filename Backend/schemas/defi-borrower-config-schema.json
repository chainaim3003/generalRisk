{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://actus.org/schemas/defi-borrower-config.json",
  "title": "DeFi Borrower Simulation Configuration",
  "description": "Configuration schema for DeFi liquidation simulation - borrower perspective (parallel to issuer-config-schema.json)",
  "type": "object",
  "required": ["config_metadata", "protocol", "simulation_timeframe"],

  "properties": {
    "config_metadata": {
      "type": "object",
      "required": ["config_id", "collection_file"],
      "properties": {
        "config_id":       { "type": "string", "minLength": 1 },
        "description":     { "type": "string" },
        "version":         { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "is_default":      { "type": "boolean" },
        "collection_file": { "type": "string", "pattern": "\\.json$" }
      }
    },

    "protocol": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": { "enum": ["inline", "file"] },
        "file":   { "type": "string" },
        "inline": {
          "type": "object",
          "required": [
            "liquidation_threshold", "loan_to_value", "liquidation_bonus",
            "health_factor_trigger", "healthy_health_factor"
          ],
          "properties": {
            "protocol_code":               { "type": "string" },
            "protocol_name":               { "type": "string" },
            "liquidation_threshold":       { "type": "number", "minimum": 0, "maximum": 1 },
            "loan_to_value":               { "type": "number", "minimum": 0, "maximum": 1 },
            "liquidation_bonus":           { "type": "number", "minimum": 0, "maximum": 0.5 },
            "liquidation_close_factor":    { "type": "number", "minimum": 0, "maximum": 1 },
            "health_factor_trigger":       { "type": "number", "minimum": 0 },
            "healthy_health_factor":       { "type": "number", "minimum": 1 },
            "target_health_factor_recovery": { "type": "number", "minimum": 1 },
            "reserve_factor":              { "type": "number", "minimum": 0, "maximum": 1 },
            "protocol_fee_bps":            { "type": "number", "minimum": 0 },
            "max_utilization_rate":        { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      }
    },

    "borrower_thresholds": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": { "enum": ["inline", "preset"] },
        "preset": { "type": "string" },
        "inline": {
          "type": "object",
          "required": [
            "min_health_factor_comfort", "repay_trigger_health_factor",
            "aggressive_repay_fraction", "moderate_repay_fraction",
            "safe_horizon_days", "urgent_days", "max_ltv_target"
          ],
          "properties": {
            "min_health_factor_comfort":       { "type": "number", "minimum": 1 },
            "repay_trigger_health_factor":     { "type": "number", "minimum": 1 },
            "aggressive_repay_fraction":       { "type": "number", "minimum": 0, "maximum": 1 },
            "moderate_repay_fraction":         { "type": "number", "minimum": 0, "maximum": 1 },
            "safe_horizon_days":               { "type": "number", "minimum": 1 },
            "urgent_days":                     { "type": "number", "minimum": 1 },
            "max_ltv_target":                  { "type": "number", "minimum": 0, "maximum": 1 },
            "gas_price_abort_gwei":            { "type": "number", "minimum": 0 },
            "flash_loan_enabled":              { "type": "boolean" },
            "flash_loan_max_usd":              { "type": "number", "minimum": 0 },
            "hedge_delta_threshold":           { "type": "number", "minimum": 0, "maximum": 1 },
            "rebalance_frequency_hours":       { "type": "number", "minimum": 1 },
            "auto_top_up_collateral":          { "type": "boolean" },
            "top_up_trigger_health_factor":    { "type": "number", "minimum": 1 }
          }
        }
      }
    },

    "market_scenario": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": { "enum": ["inline", "file"] },
        "file":   { "type": "string" }
      }
    },

    "liquidation_scenario": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": { "enum": ["inline", "file"] },
        "file":   { "type": "string" }
      }
    },

    "simulation_timeframe": {
      "type": "object",
      "required": ["frequency"],
      "properties": {
        "status_date":    { "type": "string", "format": "date-time" },
        "start_date":     { "type": "string", "format": "date-time" },
        "end_date":       { "type": "string", "format": "date-time" },
        "duration_days":  { "type": "integer", "minimum": 1, "maximum": 365 },
        "frequency":      { "enum": ["hourly", "daily", "weekly", "monthly"] }
      }
    }
  }
}
