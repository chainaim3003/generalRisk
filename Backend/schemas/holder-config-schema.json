{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://actus.org/schemas/holder-config.json",
  "title": "Holder Simulation Configuration",
  "type": "object",
  "required": ["config_metadata", "user_thresholds", "simulation_timeframe"],
  
  "properties": {
    "config_metadata": {
      "type": "object",
      "required": ["config_id", "collection_file"],
      "properties": {
        "config_id": {"type": "string", "minLength": 1},
        "description": {"type": "string"},
        "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
        "is_default": {"type": "boolean"},
        "collection_file": {"type": "string", "pattern": "\\.json$"}
      }
    },
    
    "user_thresholds": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": {"enum": ["inline", "preset"]},
        "preset": {"type": "string"},
        "inline": {
          "type": "object",
          "required": [
            "min_backing_ratio", "max_wam_days", "min_hqla_score",
            "max_attestation_age_days", "max_single_asset_concentration",
            "max_peg_deviation", "alert_on_bank_stress_above"
          ],
          "properties": {
            "min_backing_ratio": {"type": "number", "minimum": 0},
            "max_wam_days": {"type": "number", "minimum": 1},
            "min_hqla_score": {"type": "number", "minimum": 0, "maximum": 100},
            "max_attestation_age_days": {"type": "number", "minimum": 1},
            "max_single_asset_concentration": {"type": "number", "minimum": 0, "maximum": 1},
            "max_peg_deviation": {"type": "number", "minimum": 0, "maximum": 1},
            "alert_on_bank_stress_above": {"type": "number", "minimum": 0, "maximum": 1}
          }
        }
      }
    },
    
    "simulation_timeframe": {
      "type": "object",
      "required": ["frequency"],
      "properties": {
        "status_date": {"type": "string", "format": "date-time"},
        "start_date": {"type": "string", "format": "date-time"},
        "end_date": {"type": "string", "format": "date-time"},
        "duration_days": {"type": "integer", "minimum": 1, "maximum": 365},
        "frequency": {"enum": ["daily", "weekly", "monthly"]}
      }
    }
  }
}
