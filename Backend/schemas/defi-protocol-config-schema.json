{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://actus.org/schemas/defi-protocol-config.json",
  "title": "DeFi Protocol Simulation Configuration",
  "description": "Configuration schema for DeFi liquidation simulation - protocol perspective (parallel to holder-config-schema.json)",
  "type": "object",
  "required": ["config_metadata", "protocol", "protocol_thresholds", "simulation_timeframe"],

  "properties": {
    "config_metadata": {
      "type": "object",
      "required": ["config_id", "collection_file"],
      "properties": {
        "config_id":       { "type": "string", "minLength": 1 },
        "description":     { "type": "string" },
        "version":         { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "is_default":      { "type": "boolean" },
        "collection_file": { "type": "string", "pattern": "\\.json$" }
      }
    },

    "protocol": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": { "enum": ["inline", "file"] },
        "file":   { "type": "string" },
        "inline": { "type": "object" }
      }
    },

    "protocol_thresholds": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": { "enum": ["inline", "preset"] },
        "preset": { "type": "string" },
        "inline": {
          "type": "object",
          "required": [
            "min_health_factor_trigger", "healthy_health_factor",
            "target_health_factor", "max_liquidation_bonus",
            "max_cascade_depth", "liquidation_close_factor"
          ],
          "properties": {
            "min_health_factor_trigger":  { "type": "number", "minimum": 0 },
            "healthy_health_factor":      { "type": "number", "minimum": 1 },
            "target_health_factor":       { "type": "number", "minimum": 1 },
            "max_liquidation_bonus":      { "type": "number", "minimum": 0, "maximum": 0.5 },
            "max_cascade_depth":          { "type": "integer", "minimum": 1, "maximum": 20 },
            "min_collateral_ratio":       { "type": "number", "minimum": 1 },
            "gas_price_gwei_limit":       { "type": "number", "minimum": 0 },
            "max_slippage_tolerance":     { "type": "number", "minimum": 0, "maximum": 0.5 },
            "liquidation_close_factor":   { "type": "number", "minimum": 0, "maximum": 1 },
            "protocol_fee_bps":           { "type": "number", "minimum": 0 },
            "stability_fee_annual":       { "type": "number", "minimum": 0 },
            "auction_duration_hours":     { "type": "number", "minimum": 0 },
            "circuit_breaker_active":     { "type": "boolean" }
          }
        }
      }
    },

    "market_scenario": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": { "enum": ["inline", "file"] },
        "file":   { "type": "string" }
      }
    },

    "liquidation_scenario": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": { "enum": ["inline", "file"] },
        "file":   { "type": "string" }
      }
    },

    "simulation_timeframe": {
      "type": "object",
      "required": ["frequency"],
      "properties": {
        "status_date":    { "type": "string", "format": "date-time" },
        "start_date":     { "type": "string", "format": "date-time" },
        "end_date":       { "type": "string", "format": "date-time" },
        "duration_days":  { "type": "integer", "minimum": 1, "maximum": 365 },
        "frequency":      { "enum": ["hourly", "daily", "weekly", "monthly"] }
      }
    }
  }
}
