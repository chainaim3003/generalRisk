{
  "name": "risk-stablecoin-verifier",
  "version": "1.0.0",
  "description": "Simplified stablecoin risk verification system with ACTUS integration",
  "main": "dist/index.js",
  "bin": {
    "risk-verify": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "verify": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist",
    "dev": "tsc --watch",
    "server": "tsc && node dist/server.js",
    "server:dev": "tsc && node --watch dist/server.js"
  },
  "keywords": [
    "stablecoin",
    "risk-verification",
    "compliance",
    "actus"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "commander": "^11.1.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "date-fns": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.0"
  }
}
